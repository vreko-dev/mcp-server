### PostHog Integration Strategy

```typescript
// Privacy-first analytics architecture
interface AnalyticsEvent {
  event: string;
  anonymousId: string;  // NEVER userId
  properties: {
    // Allowed properties
    clientType: string;
    clientVersion: string;
    tier: string;

    // Feature-specific (sanitized)
    snapshotTrigger?: 'auto' | 'manual' | 'ai';
    aiToolDetected?: 'cursor' | 'copilot' | 'claude' | 'unknown';
    fileExtension?: string;  // ".ts", never full path

    // Heuristic improvement data
    aiConfidence?: number;
    burstDetected?: boolean;
    protectionLevel?: string;
    userAction?: 'proceed' | 'restore' | 'dismiss';
  };
}

// Property blocklist (never sent)
const BLOCKED_PROPERTIES = [
  'path', 'filePath', 'fileName', 'fullPath',
  'email', 'user', 'userId', 'name',
  'ip', 'ipAddress', 'location',
  'content', 'code', 'diff',
];

// Server-side sanitization (double-check)
function sanitizeEvent(event: AnalyticsEvent): AnalyticsEvent {
  const sanitized = { ...event };

  for (const blocked of BLOCKED_PROPERTIES) {
    delete sanitized.properties[blocked];
  }

  // Scrub IP before forwarding
  sanitized.properties.$ip = null;

  return sanitized;
}
```

