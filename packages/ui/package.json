{
	"name": "@snapback/ui",
	"version": "0.1.0",
	"description": "Shared UI components for SnapBack web and VS Code extension",
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./components": {
			"types": "./dist/components/index.d.ts",
			"import": "./dist/components/index.js"
		},
		"./vitals": {
			"types": "./dist/vitals/index.d.ts",
			"import": "./dist/vitals/index.js"
		},
		"./motion": {
			"types": "./dist/motion/index.d.ts",
			"import": "./dist/motion/index.js"
		}
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"type-check": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"dependencies": {
		"@radix-ui/react-slot": "^1.1.0",
		"@snapback/contracts": "workspace:*",
		"class-variance-authority": "catalog:",
		"clsx": "catalog:",
		"motion": "catalog:",
		"react": "catalog:",
		"react-dom": "catalog:",
		"tailwind-merge": "catalog:"
	},
	"devDependencies": {
		"@types/react": "catalog:",
		"@types/react-dom": "catalog:",
		"tsup": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:"
	},
	"peerDependencies": {
		"react": "^18.0.0",
		"react-dom": "^18.0.0"
	}
}
