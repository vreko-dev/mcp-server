{
  "name": "@snapback/core",
  "description": "Core logic for SnapBack",
  "version": "0.1.1",
  "dependencies": {
    "@modelcontextprotocol/sdk": "catalog:",
    "@snapback/config": "workspace:*",
    "@snapback/contracts": "workspace:*",
    "@types/esprima": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "async-retry": "catalog:",
    "bottleneck": "catalog:",
    "chokidar": "catalog:",
    "cosmiconfig": "catalog:",
    "dotenv": "catalog:",
    "esprima": "catalog:",
    "jscpd": "catalog:",
    "listr2": "catalog:",
    "lru-cache": "catalog:",
    "madge": "catalog:",
    "mermaid": "catalog:",
    "opossum": "catalog:",
    "p-limit": "catalog:",
    "pino": "catalog:",
    "piscina": "catalog:",
    "simple-git": "catalog:",
    "yargs": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@snapback/tsconfig": "workspace:*",
    "@types/async-retry": "catalog:",
    "@types/node": "catalog:",
    "@types/opossum": "catalog:",
    "pino-pretty": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "license": "Apache-2.0",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsup",
    "check": "biome check .",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --fix .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "type": "module",
  "types": "dist/index.d.ts"
}
