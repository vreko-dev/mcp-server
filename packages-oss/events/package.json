{
  "name": "@snapback-oss/events",
  "version": "0.2.0",
  "description": "Type-safe event bus for building reactive TypeScript applications - powered by EventEmitter2 with full async/await support",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/snapback-dev.git",
    "directory": "packages-oss/events"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup && tsc --build",
    "check": "biome check .",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --fix .",
    "test": "vitest run",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "event-bus",
    "events",
    "pub-sub",
    "message-queue",
    "event-driven",
    "async",
    "typescript",
    "developer-tools",
    "event-emitter",
    "reactive",
    "code-safety",
    "snapback",
    "oss",
    "eventemitter2",
    "type-safe"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
