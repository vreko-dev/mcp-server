{
  "name": "@snapback/mail",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup && tsc --build",
    "check": "biome check .",
    "clean": "rm -rf dist .tsbuildinfo",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --fix .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hubspot/api-client": "catalog:",
    "@react-email/components": "catalog:",
    "@react-email/render": "catalog:",
    "@snapback/config": "workspace:*",
    "@snapback/contracts": "workspace:*",
    "@snapback/infrastructure": "workspace:*",
    "@snapback/platform": "workspace:*",
    "@snapback/sdk": "workspace:*",
    "drizzle-orm": "catalog:",
    "hono": "catalog:",
    "nodemailer": "catalog:",
    "react": "catalog:",
    "react-email": "catalog:",
    "resend": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@snapback/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "@types/nodemailer": "catalog:",
    "@types/react": "catalog:",
    "@vitest/ui": "catalog:",
    "tsx": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./theme": {
      "types": "./dist/theme.d.ts",
      "default": "./dist/theme.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "default": "./dist/components/index.js"
    },
    "./templates": {
      "types": "./dist/templates/index.d.ts",
      "default": "./dist/templates/index.js"
    },
    "./services": {
      "types": "./dist/services/index.d.ts",
      "default": "./dist/services/index.js"
    },
    "./routes": {
      "types": "./dist/routes/index.d.ts",
      "default": "./dist/routes/index.js"
    }
  }
}
