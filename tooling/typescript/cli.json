{
	"$schema": "https://json.schemastore.org/tsconfig",
	"extends": "./base.json",
	"compilerOptions": {
		"outDir": "dist",
		"rootDir": "src",
		"sourceMap": true,
		"declarationDir": "dist",
		"tsBuildInfoFile": "./dist/.tsbuildinfo"
	},
	"include": ["src/**/*.ts"],
	"exclude": ["node_modules", "dist", "build", "src/**/*.js", "src/**/*.d.ts"]
}
