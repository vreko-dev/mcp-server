{
  "name": "@snapback/mcp-server",
  "version": "2.0.0",
  "description": "AI-powered code analysis server for Claude Desktop and MCP clients - risk detection, snapshots, and intelligent code safety",
  "repository": {
    "type": "git",
    "url": "https://github.com/snapback-dev/mcp-server.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "catalog:",
    "@snapback/auth": "workspace:*",
    "@snapback/config": "workspace:*",
    "@snapback/contracts": "workspace:*",
    "@snapback/core": "workspace:*",
    "@snapback/engine": "workspace:*",
    "@snapback/intelligence": "workspace:*",
    "@snapback/sdk": "workspace:*",
    "better-sqlite3": "catalog:",
    "content-type": "^1.0.5",
    "dotenv": "catalog:",
    "ky": "catalog:",
    "lru-cache": "catalog:",
    "opossum": "catalog:",
    "raw-body": "^2.5.2",
    "semver": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@snapback/cli": "workspace:*",
    "@snapback/testing": "workspace:*",
    "@snapback/tsconfig": "workspace:*",
    "@types/better-sqlite3": "catalog:",
    "@types/content-type": "^1.1.9",
    "@types/node": "catalog:",
    "@types/opossum": "catalog:",
    "@types/semver": "catalog:",
    "@vitest/ui": "catalog:",
    "hono": "catalog:",
    "tsup": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js"
    },
    "./services/AnalysisRouter": {
      "import": "./dist/services/AnalysisRouter.js"
    }
  },
  "files": [
    "dist"
  ],
  "license": "Apache-2.0",
  "scripts": {
    "build": "tsup --clean && node ../../scripts/build-utils/add-js-extensions.mjs",
    "build:fast": "pnpm --filter @snapback/mcp-server... build",
    "dev": "tsx watch src/index.ts",
    "dev:fast": "turbo build --filter=@snapback/mcp-server... --force",
    "selftest": "SNAPBACK_MCP_SELFTEST=1 node --env-file=.env.local dist/index.js",
    "start": "node --env-file=.env.local dist/index.js",
    "start:dev": "tsx src/index.ts",
    "test": "vitest run",
    "type-check": "tsc --noEmit",
    "docker-build": "docker build -t snapback-mcp:${GIT_SHA:-latest} -f apps/mcp-server/Dockerfile .",
    "docker-build:dev": "docker build -t snapback-mcp:dev -f apps/mcp-server/Dockerfile.dev .",
    "deploy": "npm publish --access public"
  },
  "type": "module"
}
