Perf budgets in CI (avg < 50 ms, p95 < 100 ms)
Measure the onWillSaveTextDocument → snapshot persisted span at the integration layer; keep micro‑benchmarks in unit/component as a smoke sanity.
// tests/integration/perf/snapshot.budget.test.ts
import { performance } from 'perf_hooks';
suite('Perf budget: snapshot-on-save', () => {
  test('avg < 50ms, p95 < 100ms', async () => {
    const times:number[] = [];
    for (let i=0; i<60; i++) {
      const start = performance.now();
      await vscode.commands.executeCommand('snapback._test.saveWithSnapshot', '/workspace/perf.ts');
      times.push(performance.now() - start);
    }
    const avg = times.reduce((a,b)=>a+b)/times.length;
    const p95 = times.sort((a,b)=>a-b)[Math.floor(times.length*0.95)];
    assert.ok(avg < 50, `avg ${avg.toFixed(1)}ms`);
    assert.ok(p95 < 100, `p95 ${p95.toFixed(1)}ms`);
  });
});

