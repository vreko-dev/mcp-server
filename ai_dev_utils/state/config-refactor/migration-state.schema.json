{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "Migration State Schema",
	"type": "object",
	"required": [
		"phase",
		"opportunities_completed",
		"opportunities_in_progress",
		"test_coverage",
		"validation_results"
	],
	"properties": {
		"phase": {
			"const": "migrate"
		},
		"opportunities_completed": {
			"type": "array",
			"items": {
				"type": "string",
				"pattern": "^OP_"
			}
		},
		"opportunities_in_progress": {
			"type": "array",
			"items": {
				"type": "string",
				"pattern": "^OP_"
			}
		},
		"opportunities_blocked": {
			"type": "array",
			"items": {
				"type": "object",
				"required": ["id", "blocker"],
				"properties": {
					"id": {
						"type": "string",
						"pattern": "^OP_"
					},
					"blocker": {
						"type": "string"
					}
				}
			}
		},
		"test_coverage": {
			"type": "object",
			"patternProperties": {
				"^.*$": {
					"type": "number",
					"minimum": 0,
					"maximum": 100
				}
			}
		},
		"validation_results": {
			"type": "object",
			"required": ["schema_validation", "business_logic_validation", "multi_source_consistency"],
			"properties": {
				"schema_validation": {
					"type": "string",
					"enum": ["PASS", "FAIL", "PENDING"]
				},
				"business_logic_validation": {
					"type": "string",
					"enum": ["PASS", "FAIL", "PENDING"]
				},
				"multi_source_consistency": {
					"type": "string",
					"enum": ["PASS", "FAIL", "PENDING"]
				},
				"performance_benchmarks": {
					"type": "string",
					"enum": ["PASS", "FAIL", "PENDING"]
				}
			}
		},
		"rollout_status": {
			"type": ["object", "null"],
			"properties": {
				"feature_flag": {
					"type": "string"
				},
				"rollout_percentage": {
					"type": "integer",
					"minimum": 0,
					"maximum": 100
				},
				"error_rate": {
					"type": "number",
					"minimum": 0,
					"maximum": 1
				},
				"user_reports": {
					"type": "integer",
					"minimum": 0
				},
				"cooldown_start": {
					"type": "string",
					"format": "date"
				}
			}
		},
		"design_artifacts": {
			"type": "object",
			"patternProperties": {
				"^OP_": {
					"type": "object",
					"properties": {
						"schema": {
							"type": "string"
						},
						"migration": {
							"type": "string"
						},
						"tests_written": {
							"type": "integer"
						},
						"status": {
							"type": "string",
							"enum": ["design_complete", "implementation_complete", "rollout_complete"]
						}
					}
				}
			}
		}
	}
}
