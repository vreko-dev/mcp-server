{
	"compilerOptions": {
		"outDir": "./dist-simple",
		"rootDir": "./src",
		"declaration": true,
		"composite": true,
		"incremental": true,
		"module": "ES2022",
		"moduleResolution": "bundler",
		"skipLibCheck": true,
		"jsx": "react-jsx",
		"target": "ES2022",
		"esModuleInterop": true,
		"strict": true
	},
	"include": ["src/**/*"]
}
