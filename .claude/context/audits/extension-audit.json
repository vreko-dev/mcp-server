{
	"phase": "S2",
	"title": "Extension Audit",
	"timestamp": "2025-11-07",
	"extension": {
		"name": "snapback-vscode",
		"version": "1.2.5",
		"displayName": "SnapBack - Code Safety Net",
		"publisher": "MarcelleLabs"
	},
	"activationEvents": [
		{
			"event": "onStartupFinished",
			"description": "Extension activates when VS Code startup is finished"
		},
		{
			"event": "onCommand:snapback.*",
			"description": "Extension activates when any snapback command is executed"
		},
		{
			"event": "workspaceContains:.snapbackrc",
			"description": "Extension activates when workspace contains a .snapbackrc file"
		}
	],
	"bundler": {
		"tool": "esbuild",
		"configFile": "esbuild.config.cjs",
		"entryPoint": "./src/extension.ts",
		"format": "cjs",
		"minify": true,
		"target": "node20",
		"outfile": "dist/extension.js",
		"external": ["vscode", "better-sqlite3"]
	},
	"bundleSize": {
		"limit": "1MB",
		"checkScript": "scripts/check-bundle-size.js",
		"estimatedSize": "TBD - Would need to build and check actual size"
	},
	"telemetry": {
		"implementation": "VSCodeTelemetry class",
		"file": "src/telemetry.ts",
		"client": "PostHog",
		"proxy": "TelemetryProxy",
		"eventBus": "SnapBackEventBus",
		"featureFlags": true
	},
	"firstRunWizard": {
		"implementation": "WelcomeView class",
		"file": "src/welcomeView.ts",
		"type": "Webview",
		"features": ["Initialize SnapBack", "Protect Entire Repository", "Documentation links"]
	},
	"heavyDependencies": [
		{
			"name": "better-sqlite3",
			"reason": "Native module for database operations",
			"external": true
		},
		{
			"name": "simple-git",
			"reason": "Git operations integration",
			"external": false
		}
	],
	"errorSurfaces": [
		{
			"type": "UI Level",
			"description": "Uses inline CodeLens + status-bar toast instead of modal dialogs for MVP",
			"file": "src/notificationManager.ts"
		},
		{
			"type": "Logging",
			"description": "Comprehensive error logging with Logger class",
			"file": "src/utils/logger.ts"
		},
		{
			"type": "Save Handler",
			"description": "Error handling in save operations with restoration fallback",
			"file": "src/handlers/SaveHandler.ts"
		}
	],
	"offlineQueue": {
		"implementation": "Partial",
		"details": [
			"Offline mode configuration available",
			"RulesManager respects offline mode setting",
			"StorageBroker provides queuing mechanism for database operations",
			"No explicit telemetry event queue for offline scenarios"
		],
		"files": [
			"src/commands/offlineModeCommands.ts",
			"src/rules/RulesManager.ts",
			"packages/sdk/src/storage/StorageBroker.ts"
		]
	}
}
