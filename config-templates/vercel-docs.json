{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd ../.. && pnpm run build --filter=@snapback/docs",
  "devCommand": "pnpm run dev",
  "installCommand": "pnpm install --frozen-lockfile",
  "framework": "nextjs",
  "outputDirectory": ".next",
  "functions": {
    "app/**/*.{js,ts,tsx}": {
      "runtime": "nodejs22.x"
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=7200"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/",
      "destination": "/getting-started",
      "permanent": false
    },
    {
      "source": "/github",
      "destination": "https://github.com/snapback-dev/snapback-oss",
      "permanent": false
    }
  ]
}
