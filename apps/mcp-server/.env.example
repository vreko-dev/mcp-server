# SnapBack MCP Server Environment Configuration
# MCP Server-specific environment variables for Model Context Protocol integration

# =============================================================================
# SNAPBACK API CONFIGURATION
# =============================================================================

# SnapBack Backend API Settings
SNAPBACK_API_URL=http://localhost:3000
SNAPBACK_API_KEY=
SNAPBACK_NO_NETWORK=true
# =============================================================================
# MCP SERVER CONFIGURATION
# =============================================================================

# Server Basic Settings
MCP_SERVER_NAME=snapback-mcp
MCP_SERVER_VERSION=0.1.0
MCP_SERVER_HOST=localhost
MCP_SERVER_PORT=3001

# Server Mode (stdio, http, websocket)
MCP_SERVER_MODE=stdio
MCP_SERVER_TRANSPORT=stdio

# =============================================================================
# MCP PROTOCOL SETTINGS
# =============================================================================

# Protocol Configuration
MCP_PROTOCOL_VERSION=2024-11-05
MCP_MAX_MESSAGE_SIZE=1048576
MCP_TIMEOUT_MS=30000

# Connection Settings
MCP_MAX_CONNECTIONS=10
MCP_CONNECTION_TIMEOUT_MS=5000
MCP_KEEP_ALIVE_INTERVAL_MS=30000

# =============================================================================
# MCP TOOLS CONFIGURATION
# =============================================================================

# Available Tools
MCP_TOOLS_ENABLED=analyze_risk,create_checkpoint,verify_ai_change,recovery_plan
MCP_TOOLS_TIMEOUT_MS=30000

# Tool-specific Settings
ANALYZE_RISK_MAX_CHANGES=1000
CREATE_CHECKPOINT_MAX_FILES=100
VERIFY_AI_CHANGE_MAX_DIFF_SIZE_MB=5
RECOVERY_PLAN_MAX_OPTIONS=10

# =============================================================================
# RESOURCE CONFIGURATION
# =============================================================================

# Resource Limits
MAX_CONCURRENT_REQUESTS=5
MAX_REQUEST_SIZE_MB=10
MAX_RESPONSE_SIZE_MB=10

# Memory Management
MAX_MEMORY_USAGE_MB=256
GC_INTERVAL_MS=60000

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================

# Authentication Settings
AUTH_ENABLED=false
AUTH_TOKEN=
API_KEY=

# Security Settings
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100
ALLOWED_ORIGINS=localhost,127.0.0.1

# CORS Configuration
CORS_ENABLED=true
CORS_ALLOW_CREDENTIALS=false

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================

# Server Logging
LOG_LEVEL=info
LOG_FORMAT=json
LOG_DESTINATION=stdout

# Request Logging
LOG_REQUESTS=true
LOG_RESPONSES=false
LOG_REQUEST_BODY=false

# =============================================================================
# HEALTH CHECK CONFIGURATION
# =============================================================================

# Health Monitoring
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_ENDPOINT=/health
HEALTH_CHECK_INTERVAL_MS=30000

# Status Reporting
STATUS_ENDPOINT=/status
METRICS_ENDPOINT=/metrics
METRICS_ENABLED=true

# =============================================================================
# INTEGRATION SETTINGS
# =============================================================================

# Core Package Integration
CORE_PACKAGE_PATH=../packages/core
STORAGE_PACKAGE_PATH=../packages/storage
CONTRACTS_PACKAGE_PATH=../packages/contracts

# External Service Integration
EXTERNAL_MCP_SERVERS=
FEDERATION_ENABLED=false

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================

# Development Mode
DEVELOPMENT_MODE=true
HOT_RELOAD_ENABLED=true
DEBUG_MCP_PROTOCOL=false

# Development Tools
ENABLE_INSPECTOR=false
INSPECTOR_PORT=9229
ENABLE_PROFILER=false

# =============================================================================
# PERFORMANCE MONITORING
# =============================================================================

# Performance Settings
PERFORMANCE_MONITORING=true
RESPONSE_TIME_TRACKING=true
MEMORY_USAGE_TRACKING=true

# Metrics Collection
COLLECT_REQUEST_METRICS=true
COLLECT_SYSTEM_METRICS=false
METRICS_RETENTION_HOURS=24

# =============================================================================
# ERROR HANDLING
# =============================================================================

# Error Configuration
ERROR_STACK_TRACES=true
ERROR_CONTEXT_SIZE=1000
DETAILED_ERROR_RESPONSES=true

# Error Reporting
ERROR_REPORTING_ENABLED=false
ERROR_REPORTING_ENDPOINT=

# =============================================================================
# CONTEXT7 INTEGRATION
# =============================================================================

# Context7 API Settings
CONTEXT7_API_KEY=
CONTEXT7_API_URL=https://context7.com/api

# Context7 Cache Settings
CONTEXT7_CACHE_TTL_SEARCH=3600
CONTEXT7_CACHE_TTL_DOCS=86400

# =============================================================================
# GRACEFUL SHUTDOWN
# =============================================================================

# Shutdown Configuration
GRACEFUL_SHUTDOWN_TIMEOUT_MS=10000
SHUTDOWN_SIGNAL=SIGTERM
DRAIN_CONNECTIONS_ON_SHUTDOWN=true

# Cleanup Settings
CLEANUP_TEMP_FILES=true
FLUSH_LOGS_ON_SHUTDOWN=true
