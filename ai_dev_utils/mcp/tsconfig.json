{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"target": "ES2022",
		"module": "ES2022",
		"moduleResolution": "bundler",
		"resolvePackageJsonExports": true,
		"resolvePackageJsonImports": true,
		"esModuleInterop": true,
		"strict": true,
		"skipLibCheck": true,
		"outDir": "dist",
		"rootDir": ".",
		"declaration": true,
		"downlevelIteration": true,
		"types": ["node"]
	},
	"include": ["*.ts"],
	"exclude": ["node_modules", "dist"]
}
