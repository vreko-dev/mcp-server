{
  "name": "@snapback-oss/config",
  "version": "0.2.0",
  "description": "Type-safe configuration management for TypeScript applications - environment-based config with validation and zero-downtime updates",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/snapback-dev.git",
    "directory": "packages-oss/config"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup && tsc --build",
    "check": "biome check .",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --fix .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "configuration",
    "config",
    "config-management",
    "environment",
    "settings",
    "typescript",
    "developer-tools",
    "config-loader",
    "type-safe",
    "validation",
    "code-safety",
    "snapback",
    "oss",
    "env",
    "dotenv"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
