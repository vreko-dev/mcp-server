# SnapBack API Environment Variables
# Copy this file to .env.local and fill in your values

# ================================
# Database Configuration
# ================================
DATABASE_URL="postgresql://username:password@localhost:5432/database_name"
DIRECT_URL="postgresql://username:password@localhost:5432/database_name"

# ================================
# Authentication Configuration
# ================================
BETTER_AUTH_SECRET="your-super-secret-auth-key-min-32-chars"
BETTER_AUTH_URL="http://localhost:3001"

# GitHub OAuth (optional)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ================================
# Redis Configuration
# ================================
REDIS_URL="redis://localhost:6379"

# ================================
# API Keys
# ================================
# Stripe (optional)
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# PostHog (optional)
POSTHOG_API_KEY=""

# Sentry (optional)
SENTRY_DSN=""

# Resend (email) (optional)
RESEND_API_KEY=""

# ================================
# Application Configuration
# ================================
NODE_ENV="development"
PORT=3001
APP_URL="http://localhost:3001"

# Logging
LOG_LEVEL="info"

# Rules Signing Key (for secure JWS signing of rules bundles)
RULES_SIGNING_KEY="your-rules-signing-key-min-32-chars"

# Environment variables for SnapBack API

# Database
DATABASE_URL=postgresql://snapback:snapback@localhost:5432/snapback

# Redis
REDIS_URL=redis://localhost:6379

# Security
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here

# Node environment
NODE_ENV=development

# Port
PORT=3001
