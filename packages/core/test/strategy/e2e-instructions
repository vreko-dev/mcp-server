Tiny—but crucial—test hooks (only in test mode)
Wire test‑only commands so E2E can assert internal state without scraping UI:
// src/testApi.ts
export function registerTestApi(ctx: vscode.ExtensionContext, onboarding: Onboarding, bus: EventBus) {
  if (process.env.SNAPBACK_TEST_MODE !== 'true') return;

  ctx.subscriptions.push(
    vscode.commands.registerCommand('snapback._test.getState', () => ({
      snapshotsCreated: ctx.globalState.get('snapback.count.snapshots', 0),
      hasSnapshots: getContextKey('snapback.hasSnapshots')
    })),
    vscode.commands.registerCommand('snapback._test.awaitSnapshot', (fsPath: string) =>
      new Promise<void>(res => bus.once('snapshot-created', e => e.fsPath === fsPath && res()))
    ),
    vscode.commands.registerCommand('snapback._test.getTelemetryBatch', () => telemetry.flushForTests()),
    vscode.commands.registerCommand('snapback._test.getOnboardingSteps', () => onboarding.getStepStates()),
    vscode.commands.registerCommand('snapback._test.saveWithSnapshot', async (fsPath: string) => {
      const doc = await vscode.workspace.openTextDocument(vscode.Uri.file(fsPath));
      await (await vscode.window.showTextDocument(doc)).edit(e => e.insert(new vscode.Position(0,0),' '));
      return doc.save();
    })
  );
}

This mirrors your TDD/debug patterns and keeps production code clean.

