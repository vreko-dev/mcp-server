{
	"$schema": "https://raw.githubusercontent.com/JamieMason/syncpack/main/schema.json",
	"dependencyTypes": ["dependencies", "devDependencies", "peerDependencies", "optionalDependencies"],
	"format": {
		"indent": "  ",
		"endOfLine": "lf",
		"sortAz": ["dependencies", "devDependencies", "peerDependencies", "optionalDependencies"]
	},
	"semverGroups": [
		{
			"range": "catalog:*",
			"dependencies": ["*"],
			"packages": ["**"]
		}
	],
	"versionGroups": [
		{
			"dependencies": ["@types/*"],
			"pinVersion": "workspace:*"
		}
	]
}
