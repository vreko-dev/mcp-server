# SnapBack Web Application - Environment Configuration Template
#
# Copy to .env.local, .env.staging, or .env.production
# For development: cp .env.example .env.local
#
# NOTE: Next.js automatically loads environment files in this order:
# 1. .env.{NODE_ENV} (e.g., .env.production)
# 2. .env.local (all environments)
# 3. .env (default values)
#
# IMPORTANT: Variables prefixed with NEXT_PUBLIC_ are exposed to the browser
# Never put secrets in NEXT_PUBLIC_ variables
#
# IMPORTANT: Never commit .env.local, .env.staging, .env.production
# Add to .gitignore: .env.local, .env.staging, .env.production

# ================================
# Environment Identification
# ================================
# Options: development | staging | production
NODE_ENV=development

# ================================
# Site & Domain Configuration
# ================================
# These NEXT_PUBLIC_ variables are exposed to browser

# Main site URL
# Development: http://localhost:3000
# Staging: https://staging.snapback.dev
# Production: https://snapback.dev
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Console/dashboard URL
# Development: http://console.localhost:3000
# Staging: https://console.staging.snapback.dev
# Production: https://console.snapback.dev
NEXT_PUBLIC_APP_URL=http://console.localhost:3000

# Documentation site URL
# Development: http://docs.localhost:3000
# Staging: https://docs.staging.snapback.dev
# Production: https://docs.snapback.dev
NEXT_PUBLIC_DOCS_URL=http://docs.localhost:3000

# Root domain for subdomain configuration
# Development: localhost
# Staging: staging.snapback.dev
# Production: snapback.dev
NEXT_PUBLIC_ROOT_DOMAIN=localhost

# ================================
# API Configuration
# ================================
# Backend API URL (server-side only)
# Development: http://localhost:3001
# Staging: https://api.staging.snapback.dev
# Production: https://api.snapback.dev
NEXT_PUBLIC_API_URL=http://localhost:3001

# ================================
# Database Configuration
# ================================
# Server-side database connection (Node.js runtime only)
# Used for server components, API routes, server actions

DATABASE_URL=postgresql://snapback:snapback@localhost:5432/snapback_dev
DIRECT_URL=postgresql://snapback:snapback@localhost:5432/snapback_dev

# ================================
# Redis Configuration
# ================================
# Redis instance for sessions, caching
REDIS_URL=redis://localhost:6379

# ================================
# Authentication (Better Auth)
# ================================
# Core authentication configuration (shared with API)

# Secret key for JWT and session signing (minimum 32 characters)
# Generate with: openssl rand -base64 32
# IMPORTANT: Must match BETTER_AUTH_SECRET in API .env
BETTER_AUTH_SECRET=dev-secret-minimum-32-characters-for-local-dev

# Better Auth service URL
# Development: http://localhost:3001
# Staging: https://api.staging.snapback.dev
# Production: https://api.snapback.dev
BETTER_AUTH_URL=http://localhost:3001

# Application base URL (used by Better Auth for redirects)
# NOTE: This should point to where Better Auth is served (API server), not the web app
# Development: http://localhost:3001
# Staging: https://api.staging.snapback.dev
# Production: https://api.snapback.dev
APP_URL=http://localhost:3001

# ================================
# OAuth Providers
# ================================
# Client-side OAuth configuration (safe in NEXT_PUBLIC_)
# Must match keys in API server

# GitHub OAuth Application
# Create at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Google OAuth Application
# Create at: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ================================
# Email Service (Resend)
# ================================
# Email sending for auth flows, notifications
# Get API key from: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key_here

# ================================
# Security & CAPTCHA
# ================================
# Cloudflare Turnstile for bot protection
# Create at: https://dash.cloudflare.com/
# Site key is safe to expose (public)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key

# Secret key is server-side only
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# ================================
# Payments (Stripe)
# ================================
# Stripe API keys for subscription management

# Public key (safe for client-side, exposed in browser)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Secret key (server-side only, never in browser)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Webhook signing secret (server-side only)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Subscription plan price IDs (from Stripe Dashboard)
STRIPE_SOLO_MONTHLY_PRICE_ID=price_solo_monthly_id
STRIPE_TEAM_MONTHLY_PRICE_ID=price_team_monthly_id
STRIPE_ENTERPRISE_MONTHLY_PRICE_ID=price_enterprise_monthly_id

# ================================
# Analytics & Monitoring (Client-Side)
# ================================
# These are exposed to browser (NEXT_PUBLIC_ prefix)

# Google Analytics
# Create at: https://analytics.google.com/
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G_your_analytics_id

# PostHog Analytics
# Get from: https://posthog.com/
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_key_here
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Sentry Error Tracking
# Create at: https://sentry.io/
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn_here

# ================================
# Monitoring & Observability (Server-Side)
# ================================
# These are server-side only (no NEXT_PUBLIC_ prefix)

# Sentry Auth Token
SENTRY_AUTH_TOKEN=your_sentry_auth_token
SENTRY_ORG=your_sentry_org
SENTRY_PROJECT=your_sentry_project

# ================================
# Storage Configuration
# ================================
# S3/Supabase for file uploads (avatars, etc.)

# S3 Configuration
S3_ACCESS_KEY_ID=your_s3_access_key
S3_SECRET_ACCESS_KEY=your_s3_secret_key
S3_ENDPOINT=https://s3.amazonaws.com
S3_REGION=us-east-1

# S3 bucket name for avatars (public)
NEXT_PUBLIC_AVATARS_BUCKET_NAME=avatars

# Supabase Configuration (alternative to S3)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ================================
# Third-Party Integrations
# ================================

# OpenAI API (for AI features, if any)
OPENAI_API_KEY=sk_your_openai_key

# HubSpot CRM (for lead management)
HUBSPOT_ACCESS_TOKEN=pat-na1-your-hubspot-access-token

# ================================
# Feature Flags
# ================================
# Enable/disable features based on environment

# Development features
NEXT_PUBLIC_FEATURE_DEBUG_MODE=true
NEXT_PUBLIC_FEATURE_VERBOSE_LOGGING=true

# Production features
# NEXT_PUBLIC_FEATURE_DEBUG_MODE=false
# NEXT_PUBLIC_FEATURE_VERBOSE_LOGGING=false

# ================================
# Development/Testing Only
# ================================
# These should be false in staging and production

# Enable test data seeding
SEED_TEST_DATA=false

# Mock external services (for testing without real API calls)
MOCK_AUTH_SERVICE=false
MOCK_PAYMENT_SERVICE=false

# Detailed logging
DEBUG=false
