{
	"$schema": "https://openapi.vercel.sh/vercel.json",
	"buildCommand": "pnpm build",
	"installCommand": "pnpm install --frozen-lockfile",
	"outputDirectory": ".next",
	"framework": "nextjs",
	"headers": [
		{
			"source": "/api/:path*",
			"headers": [
				{
					"key": "Content-Type",
					"value": "application/json"
				}
			]
		}
	],
	"redirects": [
		{
			"source": "/docs",
			"destination": "https://docs.snapback.dev",
			"permanent": false
		}
	]
}
