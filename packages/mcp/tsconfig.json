{
	"$schema": "https://json.schemastore.org/tsconfig",
	"extends": "@snapback/tsconfig/package",
	"compilerOptions": {
		"outDir": "./dist",
		"rootDir": "./src",
		"lib": ["ES2022"],
		"declaration": true,
		"declarationMap": true
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist", "build", "**/*.test.ts", "**/*.spec.ts"],
	"references": [
		{ "path": "../contracts" },
		{ "path": "../core" },
		{ "path": "../infrastructure" },
		{ "path": "../sdk" }
	]
}
