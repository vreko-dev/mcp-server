{
  "name": "@snapback/config",
  "description": "Configuration defaults for SnapBack",
  "version": "0.2.0",
  "license": "Apache-2.0",
  "author": "SnapBack Team",
  "repository": {
    "type": "git",
    "url": "https://github.com/snapback-dev.git",
    "directory": "packages/config"
  },
  "private": true,
  "dependencies": {
    "@snapback/contracts": "workspace:*",
    "chokidar": "catalog:",
    "posthog-node": "catalog:",
    "zod": "catalog:",
    "ajv": "catalog:",
    "ajv-formats": "^2.1.1"
  },
  "devDependencies": {
    "fast-check": "^4.4.0",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    },
    "./defaults": {
      "types": "./dist/defaults.d.ts",
      "default": "./dist/defaults.js"
    },
    "./env": {
      "types": "./dist/env.d.ts",
      "default": "./dist/env.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "default": "./dist/utils/index.js"
    },
    "./utils/base-url": {
      "types": "./dist/utils/base-url.d.ts",
      "default": "./dist/utils/base-url.js"
    },
    "./utils/monorepo-flattener": {
      "types": "./dist/utils/monorepo-flattener.d.ts",
      "default": "./dist/utils/monorepo-flattener.js"
    },
    "./utils/path-transformer": {
      "types": "./dist/utils/path-transformer.d.ts",
      "default": "./dist/utils/path-transformer.js"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/defaults.d.ts",
        "default": "./dist/defaults.js"
      },
      "./client": {
        "types": "./dist/client.d.ts",
        "default": "./dist/client.js"
      },
      "./server": {
        "types": "./dist/server.d.ts",
        "default": "./dist/server.js"
      },
      "./defaults": {
        "types": "./dist/defaults.d.ts",
        "default": "./dist/defaults.js"
      },
      "./env": {
        "types": "./dist/env.d.ts",
        "default": "./dist/env.js"
      },
      "./utils": {
        "types": "./dist/utils/index.d.ts",
        "default": "./dist/utils/index.js"
      },
      "./utils/base-url": {
        "types": "./dist/utils/base-url.d.ts",
        "default": "./dist/utils/base-url.js"
      },
      "./utils/monorepo-flattener": {
        "types": "./dist/utils/monorepo-flattener.d.ts",
        "default": "./dist/utils/monorepo-flattener.js"
      },
      "./utils/path-transformer": {
        "types": "./dist/utils/path-transformer.d.ts",
        "default": "./dist/utils/path-transformer.js"
      }
    }
  },
  "main": "dist/index.js",
  "bin": {
    "snapback-migrate": "./dist/bin/migrate.js"
  },
  "scripts": {
    "build": "tsup && tsc --build --force && node ../../scripts/build-utils/add-js-extensions.mjs && node ../../scripts/verify-build.js",
    "dev": "tsup --watch",
    "test": "vitest run src/__tests__",
    "check": "biome check .",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --fix .",
    "postbuild": "echo 'Build verification completed'",
    "type-check": "tsc --noEmit"
  },
  "type": "module",
  "types": "dist/index.d.ts"
}
