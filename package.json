{
  "name": "snapback-mcp-server",
  "version": "2.0.0",
  "description": "SnapBack MCP Server - Streamable HTTP transport for AI assistant integration",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "node --loader ts-node/esm src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "validate": "node scripts/validate-bundle.js",
    "validate:fix": "node scripts/validate-bundle.js --fix",
    "docker:test": "./scripts/docker-test.sh",
    "docker:shell": "./scripts/docker-test.sh --shell",
    "predeploy": "pnpm build && pnpm validate",
    "deploy": "fly deploy . --config apps/mcp-server/fly.toml --dockerfile apps/mcp-server/Dockerfile --remote-only",
    "deploy:force": "fly deploy . --config apps/mcp-server/fly.toml --dockerfile apps/mcp-server/Dockerfile --remote-only --strategy immediate",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format ."
  },
  "dependencies": {
    "@snapback/mcp": "workspace:*",
    "@snapback/platform": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "ts-node": "catalog:",
    "tsup": "catalog:",
    "vitest": "catalog:",
    "@vitest/coverage-v8": "catalog:"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
