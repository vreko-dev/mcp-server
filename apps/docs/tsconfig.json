{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"jsx": "preserve",
		"lib": ["dom", "dom.iterable", "esnext"],
		"plugins": [
			{
				"name": "next"
			}
		],
		"paths": {
			"@/*": ["./"],
			"@/components/*": ["./components/*"],
			"@/lib/*": ["./lib/*"],
			".source": ["./.source"],
			".source/*": ["./.source/*"]
		},
		"noEmit": true,
		"module": "esnext"
	},
	"include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts", ".source/**/*.ts"],
	"exclude": ["node_modules"]
}
