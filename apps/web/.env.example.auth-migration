# API Configuration
# URL for server-side API calls (backend rewrites)
API_URL="http://localhost:3001"

# Public URL for client-side calls
NEXT_PUBLIC_API_URL="http://localhost:3001"

# Application URLs
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Feature Flags
# Enable new Better Auth implementation
FEATURE_NEW_AUTH="true"

# Organizations (enable after P0 complete)
FEATURE_ORGANIZATIONS="false"

# Billing (keep disabled for demo)
FEATURE_BILLING="false"

# 2FA Support (defer to P2)
FEATURE_2FA="false"

# Passkeys Support (defer to P2)
FEATURE_PASSKEYS="false"

# OAuth Providers (optional)
NEXT_PUBLIC_GITHUB_OAUTH_ENABLED="false"
NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED="false"

# Analytics (optional)
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST=""

# Node Environment
NODE_ENV="development"
