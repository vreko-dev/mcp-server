{
  "name": "snapback-mcp-server",
  "version": "1.0.0",
  "description": "SnapBack MCP Server - Remote HTTP endpoint for AI assistant integration",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "node --loader ts-node/esm src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format ."
  },
  "dependencies": {
    "@node-rs/argon2": "catalog:",
    "@snapback/auth": "workspace:*",
    "@snapback/platform": "workspace:*",
    "drizzle-orm": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "ts-node": "catalog:",
    "vitest": "catalog:",
    "@vitest/coverage-v8": "catalog:"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
