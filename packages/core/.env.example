# SnapBack Core Package Environment Configuration
# Core-specific environment variables for business logic and integrations

# =============================================================================
# CORE FRAMEWORK SETTINGS
# =============================================================================

# Feature Flags for Core Package
SNAPBACK_CORE_FEATURES={"guardian.enabled": true, "ai_detection.enabled": true, "threat_detection.enabled": true}

# Core Logging Configuration
SNAPBACK_LOG_LEVEL=info
SNAPBACK_DEBUG=false

# =============================================================================
# MCP CLIENT CONFIGURATION
# =============================================================================

# MCP Client Settings
MCP_CLIENT_TIMEOUT_MS=5000
MCP_CLIENT_MAX_CONNECTIONS=4
MCP_CLIENT_RETRY_ATTEMPTS=3

# MCP Federation Settings
MCP_FEDERATION_ENABLED=true
MCP_FEDERATION_DISCOVERY_TIMEOUT_MS=10000

# =============================================================================
# CODE ANALYSIS CONFIGURATION
# =============================================================================

# Guardian Analysis Settings
GUARDIAN_MAX_FILE_SIZE_MB=5
GUARDIAN_ANALYSIS_TIMEOUT_MS=30000
GUARDIAN_PARALLEL_ANALYSIS=true

# ESLint Integration
ESLINT_CONFIG_PATH=.eslintrc.js
ESLINT_CACHE_ENABLED=true
ESLINT_MAX_WARNINGS=10

# AST Analysis Settings
AST_PARSE_TIMEOUT_MS=10000
AST_MAX_COMPLEXITY=50
AST_MAX_NESTING_DEPTH=10

# =============================================================================
# AI DETECTION CONFIGURATION
# =============================================================================

# AI Detection Engine Settings
AI_DETECTION_ENABLED=true
AI_DETECTION_BURST_THRESHOLD=5
AI_DETECTION_TIME_WINDOW_MS=10000
AI_DETECTION_MIN_FILE_SIZE=1000

# =============================================================================
# THREAT DETECTION CONFIGURATION
# =============================================================================

# Security Threat Detection
THREAT_DETECTION_ENABLED=true
THREAT_DETECTION_SEVERITY_THRESHOLD=0.7
THREAT_DETECTION_PATTERNS=hardcoded_secrets,eval_usage,file_system_access

# Security Pattern Matching
SECURITY_PATTERN_TIMEOUT_MS=5000
SECURITY_MAX_FILE_SCAN_SIZE_MB=10

# =============================================================================
# GIT INTEGRATION CONFIGURATION
# =============================================================================

# Git Integration Settings
GIT_INTEGRATION_ENABLED=true
GIT_MAX_DIFF_SIZE_MB=5
GIT_TIMEOUT_MS=10000

# Git Repository Settings
GIT_DEFAULT_REMOTE=origin
GIT_DEFAULT_BRANCH=main
GIT_EXCLUDED_PATHS=node_modules,dist,coverage,.git

# =============================================================================
# CIRCUIT BREAKER CONFIGURATION
# =============================================================================

# Circuit Breaker Settings for Core Services
CIRCUIT_BREAKER_ENABLED=true
CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
CIRCUIT_BREAKER_RECOVERY_TIMEOUT_MS=30000
CIRCUIT_BREAKER_TIMEOUT_MS=5000

# =============================================================================
# CACHING CONFIGURATION
# =============================================================================

# LRU Cache Settings
CACHE_ENABLED=true
CACHE_MAX_SIZE=1000
CACHE_TTL_MS=300000

# Library Documentation Cache
DOCS_CACHE_ENABLED=true
DOCS_CACHE_TTL_MS=1800000
DOCS_CACHE_MAX_SIZE=500

# =============================================================================
# CONCURRENCY CONFIGURATION
# =============================================================================

# Concurrency Control
MAX_CONCURRENT_OPERATIONS=4
OPERATION_TIMEOUT_MS=30000
QUEUE_MAX_SIZE=100

# Worker Pool Settings
WORKER_POOL_SIZE=2
WORKER_TIMEOUT_MS=60000

# =============================================================================
# FILE SYSTEM WATCHER CONFIGURATION
# =============================================================================

# File Watcher Settings
WATCHER_ENABLED=true
WATCHER_DEBOUNCE_MS=300
WATCHER_POLL_INTERVAL_MS=1000

# File Watcher Exclusions
WATCHER_IGNORED_PATTERNS=node_modules/**,dist/**,.git/**,coverage/**

# =============================================================================
# DEPENDENCY ANALYSIS CONFIGURATION
# =============================================================================

# Dependency Analyzer Settings
DEPENDENCY_ANALYSIS_ENABLED=true
DEPENDENCY_SCAN_TIMEOUT_MS=30000
DEPENDENCY_MAX_DEPTH=10

# Package Analysis
PACKAGE_ANALYSIS_TIMEOUT_MS=10000
PACKAGE_VULNERABILITY_CHECK=true

# =============================================================================
# PERFORMANCE MONITORING
# =============================================================================

# Performance Metrics
PERFORMANCE_METRICS_ENABLED=true
PERFORMANCE_SAMPLE_RATE=0.1
MEMORY_MONITORING_ENABLED=true

# Resource Limits
MAX_MEMORY_USAGE_MB=512
MAX_CPU_USAGE_PERCENT=80