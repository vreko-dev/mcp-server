  metrics: {
    snapshotsToday: (userId: string) => `metrics:snapshots:${userId}`,
    aiDetections: (userId: string) => `metrics:ai:${userId}`,
  },

  // Pub/sub channels
  channels: {
    userEvents: (userId: string) => `events:${userId}`,
    orgEvents: (orgId: string) => `org:events:${orgId}`,
  },
};

// Rate limiting implementation
class RateLimiter {
  constructor(private redis: Redis) {}

  async check(key: string, limit: number, window: number): Promise<RateLimitResult> {
    const current = await this.redis.incr(`rate:${key}`);

    if (current === 1) {
      await this.redis.expire(`rate:${key}`, window);
    }

    return {
      allowed: current <= limit,
      remaining: Math.max(0, limit - current),
      resetAt: Date.now() + window * 1000,
    };
  }
}

