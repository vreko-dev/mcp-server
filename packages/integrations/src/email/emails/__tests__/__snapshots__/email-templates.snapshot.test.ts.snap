exports[`Email Template Snapshot Tests > CancellationEmail > should match snapshot with retention offer 1`] = `"<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd"><html dir="ltr" lang="en"><head><meta content="text/html; charset=UTF-8" http-equiv="Content-Type"/><meta name="x-apple-disable-message-reformatting"/></head><body style="background-color:#f6f9fc"><!--$--><div style="display:none;overflow:hidden;line-height:1px;opacity:0;max-height:0;max-width:0" data-skip-in-text="true">We&#x27;re sorry to see you go - Your SnapBack subscription has been canceled<div> ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿</div></div><table border="0" width="100%" cellPadding="0" cellSpacing="0" role="presentation" align="center"><tbody><tr><td style="background-color:#f6f9fc;font-family:-apple-system,BlinkMacSystemFont,&quot;Segoe UI&quot;,Roboto,&quot;Helvetica Neue&quot;,Ubuntu,sans-serif"><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="max-width:37.5em;background-color:#ffffff;margin:0 auto;padding:20px 0 48px;margin-bottom:64px"><tbody><tr style="width:100%"><td><h1 style="color:#333;font-size:24px;font-weight:bold;margin:40px 0;padding:0 40px">We&#x27;re Sorry to See You Go</h1><p style="font-size:16px;line-height:26px;color:#333;padding:0 40px;margin-top:16px;margin-bottom:16px">Your SnapBack subscription has been successfully canceled. We wanted to take a moment to thank you for trying SnapBack.</p><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="padding:0 40px;margin-top:24px"><tbody><tr><td><h1 style="color:#333;font-size:18px;font-weight:bold;margin:24px 0 16px">What Happens Next:</h1><p style="font-size:16px;line-height:26px;color:#333;padding:0 40px;margin-top:16px;margin-bottom:16px">• Your subscription benefits will continue until the end of your current billing period<br/>• You&#x27;ll be downgraded to the free tier with 1,000 snapshots<br/>• Cloud backup will be disabled (local snapshots are preserved)<br/>• You can reactivate anytime without losing your data</p></td></tr></tbody></table><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="padding:24px 40px;text-align:center;background-color:#f6f9fc;margin:24px 40px;border-radius:8px"><tbody><tr><td><h1 style="color:#333;font-size:18px;font-weight:bold;margin:24px 0 16px">Special Offer</h1><p style="font-size:16px;line-height:26px;color:#333;padding:0 40px;margin-top:16px;margin-bottom:16px">Changed your mind? <strong>Get 25% off if you resubscribe within 7 days</strong></p><a href="https://snapback.dev/pricing" style="color:#fff;text-decoration-line:none;background-color:#000000;border-radius:6px;font-size:16px;font-weight:bold;text-decoration:none;text-align:center;display:inline-block;padding:12px 24px;margin-top:16px" target="_blank">Resubscribe Now</a></td></tr></tbody></table><hr style="width:100%;border:none;border-top:1px solid #eaeaea;border-color:#e6ebf1;margin:20px 0"/><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="padding:0 40px;margin-top:24px"><tbody><tr><td><h1 style="color:#333;font-size:18px;font-weight:bold;margin:24px 0 16px">We&#x27;d Love Your Feedback</h1><p style="font-size:16px;line-height:26px;color:#333;padding:0 40px;margin-top:16px;margin-bottom:16px">Help us improve SnapBack by sharing why you canceled. It only takes 2 minutes and helps us serve developers better.</p><a href="https://snapback.dev/feedback?reason=cancellation" style="color:#556cd6;text-decoration-line:none;font-size:16px;text-decoration:underline" target="_blank">Share Your Feedback</a></td></tr></tbody></table><hr style="width:100%;border:none;border-top:1px solid #eaeaea;border-color:#e6ebf1;margin:20px 0"/><p style="font-size:14px;line-height:24px;color:#8898aa;padding:0 40px;margin-top:32px;margin-bottom:16px">Have questions? Contact us at<!-- --> <a href="mailto:support@snapback.dev" style="color:#556cd6;text-decoration-line:none;text-decoration:underline" target="_blank">support@snapback.dev</a><br/><br/>SnapBack - Code Breaks. SnapBack.</p></td></tr></tbody></table></td></tr></tbody></table><!--7--><!--/$--></body></html>"`;

exports[`Email Template Snapshot Tests > PaymentFailedEmail > should match snapshot with update payment URL 1`] = `"<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd"><html dir="ltr" lang="en"><head><meta content="text/html; charset=UTF-8" http-equiv="Content-Type"/><meta name="x-apple-disable-message-reformatting"/></head><body style="background-color:#f6f9fc"><!--$--><div style="display:none;overflow:hidden;line-height:1px;opacity:0;max-height:0;max-width:0" data-skip-in-text="true">Payment Failed - Please Update Payment Method<div> ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿</div></div><table border="0" width="100%" cellPadding="0" cellSpacing="0" role="presentation" align="center"><tbody><tr><td style="background-color:#f6f9fc;font-family:-apple-system,BlinkMacSystemFont,&quot;Segoe UI&quot;,Roboto,&quot;Helvetica Neue&quot;,Ubuntu,sans-serif"><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="max-width:37.5em;background-color:#ffffff;margin:0 auto;padding:20px 0 48px;margin-bottom:64px"><tbody><tr style="width:100%"><td><h1 style="color:#333;font-size:24px;font-weight:bold;margin:40px 0;padding:0 40px">Payment Failed</h1><p style="font-size:16px;line-height:26px;color:#333;padding:0 40px;margin-top:16px;margin-bottom:16px">We were unable to process your payment for SnapBack. Your subscription benefits are at risk.</p><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="padding:24px 40px;background-color:#fef3c7;margin:24px 40px;border-radius:8px;border-left:4px solid #f59e0b"><tbody><tr><td><p style="font-size:16px;line-height:24px;color:#92400e;font-weight:bold;margin:0;margin-top:0;margin-bottom:0;margin-left:0;margin-right:0">Please update your payment method within 3 days to avoid service interruption</p></td></tr></tbody></table><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="padding:24px 40px;text-align:center"><tbody><tr><td><a href="https://snapback.dev/settings/billing" style="color:#fff;text-decoration-line:none;background-color:#dc2626;border-radius:6px;font-size:16px;font-weight:bold;text-decoration:none;text-align:center;display:inline-block;padding:12px 24px" target="_blank">Update Payment Method</a></td></tr></tbody></table><hr style="width:100%;border:none;border-top:1px solid #eaeaea;border-color:#e6ebf1;margin:20px 0"/><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="padding:0 40px;margin-top:24px"><tbody><tr><td><h1 style="color:#333;font-size:18px;font-weight:bold;margin:24px 0 16px">Common Payment Issues:</h1><p style="font-size:16px;line-height:26px;color:#333;padding:0 40px;margin-top:16px;margin-bottom:16px">• Insufficient funds in your account<br/>• Expired credit card<br/>• Card declined by your bank<br/>• Incorrect billing information<br/></p><p style="font-size:16px;line-height:26px;color:#333;padding:0 40px;margin-top:16px;margin-bottom:16px">Most payment issues can be resolved by updating your payment method or contacting your bank.</p></td></tr></tbody></table><hr style="width:100%;border:none;border-top:1px solid #eaeaea;border-color:#e6ebf1;margin:20px 0"/><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="padding:0 40px;margin-top:24px"><tbody><tr><td><h1 style="color:#333;font-size:18px;font-weight:bold;margin:24px 0 16px">Need Help?</h1><p style="font-size:16px;line-height:26px;color:#333;padding:0 40px;margin-top:16px;margin-bottom:16px">If you&#x27;re experiencing technical difficulties or have questions about your billing, our support team is here to help.</p><p style="font-size:16px;line-height:26px;color:#333;padding:0 40px;margin-top:16px;margin-bottom:16px"><a href="mailto:support@snapback.dev" style="color:#556cd6;text-decoration-line:none;text-decoration:underline" target="_blank">support@snapback.dev</a></p></td></tr></tbody></table><hr style="width:100%;border:none;border-top:1px solid #eaeaea;border-color:#e6ebf1;margin:20px 0"/><p style="font-size:14px;line-height:24px;color:#8898aa;padding:0 40px;margin-top:32px;margin-bottom:16px">Don&#x27;t want to continue? You can<!-- --> <a href="https://snapback.dev/settings/billing?action=cancel" style="color:#556cd6;text-decoration-line:none;text-decoration:underline" target="_blank">cancel your subscription</a> <!-- -->at any time.<br/><br/>SnapBack - Code Breaks. SnapBack.</p></td></tr></tbody></table></td></tr></tbody></table><!--7--><!--/$--></body></html>"`;

exports[`Email Template Snapshot Tests > PaymentReceiptEmail > should match snapshot for $49.99 payment 1`] = `"<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd"><html dir="ltr" lang="en"><head><meta content="text/html; charset=UTF-8" http-equiv="Content-Type"/><meta name="x-apple-disable-message-reformatting"/></head><body style="background-color:#f6f9fc"><!--$--><div style="display:none;overflow:hidden;line-height:1px;opacity:0;max-height:0;max-width:0" data-skip-in-text="true">Payment Receipt - $49.99 - SnapBack<div> ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿</div></div><table border="0" width="100%" cellPadding="0" cellSpacing="0" role="presentation" align="center"><tbody><tr><td style="background-color:#f6f9fc;font-family:-apple-system,BlinkMacSystemFont,&quot;Segoe UI&quot;,Roboto,&quot;Helvetica Neue&quot;,Ubuntu,sans-serif"><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="max-width:37.5em;background-color:#ffffff;margin:0 auto;padding:20px 0 48px;margin-bottom:64px"><tbody><tr style="width:100%"><td><h1 style="color:#333;font-size:24px;font-weight:bold;margin:40px 0;padding:0 40px">Payment Receipt</h1><p style="font-size:16px;line-height:26px;color:#333;padding:0 40px;margin-top:16px;margin-bottom:16px">Thank you for your payment! Your SnapBack subscription is active and your code is protected.</p><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="padding:24px 40px;background-color:#f6f9fc;margin:24px 40px;border-radius:8px"><tbody><tr><td><table style="width:100%"><tbody><tr><td style="color:#6b7280;font-size:14px;padding-bottom:12px;width:40%">Amount Paid:</td><td style="color:#333;font-size:16px;font-weight:bold;padding-bottom:12px;text-align:right">$<!-- -->49.99<!-- --> <!-- -->USD</td></tr><tr><td style="color:#6b7280;font-size:14px;padding-bottom:12px;width:40%">Date:</td><td style="color:#333;font-size:16px;font-weight:bold;padding-bottom:12px;text-align:right">December 3, 2025</td></tr><tr><td style="color:#6b7280;font-size:14px;padding-bottom:12px;width:40%">Service:</td><td style="color:#333;font-size:16px;font-weight:bold;padding-bottom:12px;text-align:right">SnapBack Subscription</td></tr></tbody></table></td></tr></tbody></table><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="padding:24px 40px;text-align:center"><tbody><tr><td><a href="https://snapback.dev/invoice/inv_123" style="color:#fff;text-decoration-line:none;background-color:#000000;border-radius:6px;font-size:16px;font-weight:bold;text-decoration:none;text-align:center;display:inline-block;padding:12px 24px" target="_blank">View Full Invoice</a></td></tr></tbody></table><hr style="width:100%;border:none;border-top:1px solid #eaeaea;border-color:#e6ebf1;margin:20px 0"/><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="padding:0 40px;margin-top:24px"><tbody><tr><td><h1 style="color:#333;font-size:18px;font-weight:bold;margin:24px 0 16px">Your Subscription Benefits:</h1><p style="font-size:16px;line-height:26px;col