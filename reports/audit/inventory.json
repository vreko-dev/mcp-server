{
	"meta": {
		"product": "SnapBack",
		"audit_date": "2025-11-07",
		"mode": "read-only audit",
		"owner": "Qwynn"
	},
	"repository": {
		"structure": {
			"root_files": [
				".dockerignore",
				".editorconfig",
				".env.docker.example",
				".env.local.example",
				".gitignore",
				".gitleaks.toml",
				".lefthook.yml",
				".npmrc",
				".snapbackignore",
				".snapbackprotected",
				".syncpackrc.json",
				"ACCESS_DASHBOARD.md",
				"ARCHITECTURE.md",
				"CLAUDE.md",
				"COMMIT_AND_DEPLOY.md",
				"COMPREHENSIVE_ARCHITECTURE_ANALYSIS.md",
				"CONTRIBUTING.md",
				"Dockerfile",
				"Dockerfile.dev",
				"README.md",
				"biome.json",
				"package.json",
				"pnpm-lock.yaml",
				"pnpm-workspace.yaml",
				"qoder-config.yaml",
				"renovate.json",
				"tsconfig.base.json",
				"tsconfig.build.json",
				"tsconfig.json",
				"turbo.json",
				"vitest.config.ts",
				"vitest.workspace.ts"
			],
			"directories": [
				".changeset",
				".claude",
				".cursor",
				".git",
				".github",
				".test-audit-tmp",
				"ARCHIVE",
				"apps",
				"builder_pack",
				"claudedocs",
				"config",
				"docker",
				"docs",
				"examples",
				"extensions",
				"packages",
				"refactor",
				"reports",
				"scripts",
				"test",
				"tooling",
				"tools"
			]
		}
	},
	"workspaces": {
		"pnpm_workspace": ["config", "apps/**", "packages/**", "tooling/*"]
	},
	"pipelines": {
		"github_workflows": [
			"ci-cd.yml",
			"ci.yml",
			"cli-validate.yml",
			"config-gates.yml",
			"dependency-update.yml",
			"deploy-mcp.yml",
			"deploy-web.yml",
			"gitleaks.yml",
			"mcp-validate.yml",
			"publish-cli.yml",
			"publish-extension.yml",
			"publish-vscode-extension.yml",
			"release.yml",
			"security-scan.yml",
			"snapshot-release.yml",
			"sync-public-repo.yml",
			"turborepo-ci.yml",
			"update-version.yml",
			"validate-architecture.yml",
			"validate-prs.yml",
			"vscode-performance.yml",
			"vscode-test.yml",
			"vscode-validate.yml",
			"web-validate.yml"
		],
		"azure_pipelines": []
	},
	"apps": {
		"cli": {
			"path": "apps/cli",
			"description": "Command-line interface for SnapBack"
		},
		"mcp_server": {
			"path": "apps/mcp-server",
			"dependencies": [
				"@modelcontextprotocol/sdk",
				"@snapback/analytics",
				"@snapback/auth",
				"@snapback/config",
				"@snapback/contracts",
				"@snapback/core",
				"@snapback/events",
				"@snapback/github-action",
				"@snapback/integrations",
				"@snapback/policy-engine",
				"@snapback/sdk"
			],
			"description": "Model Context Protocol server for AI assistant integration"
		},
		"vscode": {
			"path": "apps/vscode",
			"engines": {
				"vscode": "^1.99.0"
			},
			"activation_events": ["onStartupFinished", "onCommand:snapback.*", "workspaceContains:.snapbackrc"],
			"description": "VS Code extension for SnapBack protection"
		},
		"web": {
			"path": "apps/web",
			"framework": "Next.js",
			"dependencies": [
				"@sentry/nextjs",
				"@snapback/api-service",
				"@snapback/auth",
				"@snapback/config",
				"@snapback/core",
				"@snapback/infrastructure",
				"@snapback/integrations",
				"@snapback/platform",
				"next",
				"react",
				"react-dom"
			],
			"analytics": ["PostHog", "Sentry"],
			"description": "Web portal/dashboard for SnapBack"
		}
	},
	"packages": {
		"analytics": {
			"path": "packages/analytics",
			"description": "Analytics events and ingestion handling"
		},
		"api": {
			"path": "apps/api",
			"description": "API services and routes"
		},
		"auth": {
			"path": "packages/auth",
			"description": "Authentication services"
		},
		"config": {
			"path": "packages/config",
			"description": "Configuration management"
		},
		"contracts": {
			"path": "packages/contracts",
			"description": "Shared contracts and types"
		},
		"core": {
			"path": "packages/core",
			"description": "Core SnapBack functionality"
		},
		"events": {
			"path": "packages/events",
			"description": "Event system and telemetry"
		},
		"infrastructure": {
			"path": "packages/infrastructure",
			"description": "Infrastructure utilities and logging"
		},
		"integrations": {
			"path": "packages/integrations",
			"description": "Third-party integrations"
		},
		"platform": {
			"path": "packages/platform",
			"description": "Database platform and schema",
			"orm": "Drizzle ORM",
			"migrations_path": "packages/platform/drizzle/migrations"
		},
		"policy_engine": {
			"path": "packages/policy-engine",
			"description": "Policy evaluation engine"
		},
		"sdk": {
			"path": "packages/sdk",
			"description": "SnapBack SDK for various platforms"
		}
	},
	"database": {
		"orm": "Drizzle ORM",
		"migrations": [
			"0001_core.sql",
			"0001_snapback_core_tables.sql",
			"0001_wild_psynapse.sql",
			"0002_snapshots.sql",
			"0003_auth.sql",
			"0003_supabase_extensions.sql",
			"0004_views.sql",
			"0005_retention.sql",
			"0006_telemetry_daily_metrics.sql"
		],
		"telemetry_tables": [
			"telemetry_events",
			"telemetry_idempotency_keys",
			"telemetry_daily_stats",
			"agent_suggestions",
			"post_accept_outcomes",
			"policy_evaluations",
			"loops",
			"feedback"
		]
	},
	"analytics": {
		"posthog": {
			"client_side": true,
			"webhook_handler": true
		},
		"sentry": {
			"used_in": ["web_app"]
		},
		"event_types": [
			"snapshot_created",
			"snapshot_restored",
			"ai_edit_detected",
			"ai_edit_accepted",
			"warning_shown",
			"dashboard_viewed",
			"onboarding_started",
			"subscription_started"
		]
	},
	"documentation": {
		"systems": ["Fumadocs", "Nextra"],
		"paths": ["docs/", "apps/web/app/(docs)/"]
	}
}
