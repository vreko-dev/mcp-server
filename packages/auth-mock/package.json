{
  "name": "@snapback/auth-mock",
  "version": "0.0.1",
  "dependencies": {
    "@snapback/auth": "workspace:*"
  },
  "devDependencies": {
    "@snapback/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "private": true,
  "scripts": {
    "build": "tsup",
    "test": "test -d test && vitest run || echo 'No test directory found, skipping tests'",
    "test:coverage": "test -d test && vitest run --coverage || echo 'No test directory found, skipping tests'"
  },
  "type": "module",
  "types": "./dist/index.d.ts"
}
