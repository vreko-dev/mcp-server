# pnpm configuration for SnapBack monorepo

# Hoist all dependencies to node_modules/.pnpm/node_modules
# This helps with Better Auth's dynamic drizzle-orm imports
hoist=true

# Hoist workspace packages
hoist-workspace-packages=true

# PUBLIC HOIST PATTERN - Critical for Better Auth + drizzle-orm
# This hoists drizzle-orm to the root node_modules so Better Auth can find it
public-hoist-pattern[]=*drizzle-orm*
public-hoist-pattern[]=*better-sqlite3*

# SHAMEFULLY HOIST - Forces all dependencies to root node_modules
# Required for Better Auth's dynamic imports to work correctly
shamefully-hoist=true

# Resolve peer dependencies from workspace root for consistency
resolve-peers-from-workspace-root=true

# Strict peer dependencies (recommended for monorepos)
strict-peer-dependencies=false
