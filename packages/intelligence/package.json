{
  "name": "@snapback/intelligence",
  "version": "0.1.0",
  "description": "Unified intelligence layer for SnapBack - validation, learning, and context retrieval",
  "license": "Apache-2.0",
  "author": "SnapBack Team",
  "repository": {
    "type": "git",
    "url": "https://github.com/snapback-dev.git",
    "directory": "packages/intelligence"
  },
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./context": {
      "types": "./dist/context/index.d.ts",
      "default": "./dist/context/index.js"
    },
    "./validation": {
      "types": "./dist/validation/index.d.ts",
      "default": "./dist/validation/index.js"
    },
    "./learning": {
      "types": "./dist/learning/index.d.ts",
      "default": "./dist/learning/index.js"
    },
    "./storage": {
      "types": "./dist/storage/index.d.ts",
      "default": "./dist/storage/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "default": "./dist/types/index.js"
    },
    "./policy": {
      "types": "./dist/policy/index.d.ts",
      "default": "./dist/policy/index.js"
    },
    "./vitals": {
      "types": "./dist/vitals/index.d.ts",
      "default": "./dist/vitals/index.js"
    },
    "./composer": {
      "types": "./dist/composer/index.d.ts",
      "default": "./dist/composer/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "context": ["./dist/context/index.d.ts"],
      "validation": ["./dist/validation/index.d.ts"],
      "learning": ["./dist/learning/index.d.ts"],
      "storage": ["./dist/storage/index.d.ts"],
      "types": ["./dist/types/index.d.ts"],
      "policy": ["./dist/policy/index.d.ts"],
      "vitals": ["./dist/vitals/index.d.ts"],
      "composer": ["./dist/composer/index.d.ts"]
    }
  },
  "scripts": {
    "build": "tsup && tsc --build tsconfig.build.json --force && node ../../scripts/build-utils/add-js-extensions.mjs",
    "check": "biome check .",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --fix .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "atomically": "^2.0.0",
    "zod": "catalog:"
  },
  "optionalDependencies": {
    "@huggingface/transformers": "^3.0.0"
  },
  "devDependencies": {
    "@snapback/testing": "workspace:*",
    "@snapback/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "sql.js": "^1.10.0"
  },
  "peerDependenciesMeta": {
    "sql.js": {
      "optional": true
    }
  },
  "keywords": [
    "intelligence",
    "validation",
    "learning",
    "patterns",
    "context"
  ],
  "sideEffects": false
}
