# Email Service Configuration

# ============================================
# Environment
# ============================================
NODE_ENV=development  # production, staging, development, test

# ============================================
# Email Provider (Resend)
# ============================================
# Get API key from: https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# ============================================
# Email Provider (Fallback: Nodemailer SMTP)
# ============================================
# Used when RESEND_API_KEY not set or NODE_ENV != production
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false  # true for port 465, false for other ports
SMTP_USER=
SMTP_PASSWORD=

# ============================================
# Email Configuration
# ============================================
EMAIL_FROM="SnapBack <protection@snapback.dev>"
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# Token Configuration
# ============================================
# Secret for HMAC signing of unsubscribe tokens
# Min 32 characters - generate with: openssl rand -base64 32
# Falls back to BETTER_AUTH_SECRET if not set
UNSUBSCRIBE_TOKEN_SECRET=your_token_secret_min_32_chars

# ============================================
# HubSpot Integration
# ============================================
# Get token from: https://app.hubspot.com/l/personal-access-key/
HUBSPOT_ACCESS_TOKEN=pat_your_hubspot_access_token

# ============================================
# Database (Required for email preferences)
# ============================================
DATABASE_URL=postgresql://user:password@localhost:5432/snapback

# ============================================
# Authentication (Required for context)
# ============================================
BETTER_AUTH_SECRET=your_auth_secret_min_32_chars
BETTER_AUTH_URL=http://localhost:3001
