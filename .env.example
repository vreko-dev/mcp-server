# SnapBack Monorepo - Environment Configuration Template
#
# Copy this file to .env.local (development), .env.staging, or .env.production
# Then fill in values appropriate for your environment
#
# IMPORTANT: Never commit sensitive values. Use .gitignore to protect:
# - .env.local (development)
# - .env.staging (staging secrets)
# - .env.production (production secrets)

# ================================
# Environment Identification
# ================================
# Options: development | staging | production
NODE_ENV=development

# Application name and version
APP_NAME=SnapBack
APP_VERSION=1.0.0

# ================================
# Database Configuration
# ================================
# PostgreSQL connection strings
# IMPORTANT: Use DIRECT_URL for migrations, DATABASE_URL for application

# Development: local PostgreSQL instance
# DATABASE_URL=postgresql://snapback:snapback@localhost:5432/snapback_dev
# DIRECT_URL=postgresql://snapback:snapback@localhost:5432/snapback_dev

# Staging: staging database server
# DATABASE_URL=postgresql://snapback_staging:${PASSWORD}@staging-db.internal:5432/snapback_staging
# DIRECT_URL=postgresql://snapback_staging:${PASSWORD}@staging-db.internal:5432/snapback_staging

# Production: production database server
# DATABASE_URL=postgresql://snapback_prod:${PASSWORD}@prod-db.internal:5432/snapback_prod
# DIRECT_URL=postgresql://snapback_prod:${PASSWORD}@prod-db.internal:5432/snapback_prod

DATABASE_URL=postgresql://username:password@localhost:5432/snapback
DIRECT_URL=postgresql://username:password@localhost:5432/snapback

# ================================
# Redis Configuration
# ================================
# Redis instance for caching, sessions, rate limiting

# Development: local Redis
# REDIS_URL=redis://localhost:6379

# Staging: staging Redis
# REDIS_URL=redis://:${PASSWORD}@staging-redis.internal:6379

# Production: production Redis (cluster recommended)
# REDIS_URL=redis://:${PASSWORD}@prod-redis.internal:6379

REDIS_URL=redis://localhost:6379

# ================================
# Authentication (Better Auth)
# ================================
# Core authentication configuration

# Secret key for signing tokens (minimum 32 characters, use: openssl rand -base64 32)
BETTER_AUTH_SECRET=your-super-secret-auth-key-minimum-32-characters

# Better Auth service URL (where auth handlers are available)
# Development: local service
# BETTER_AUTH_URL=http://localhost:3001

# Staging: staging domain
# BETTER_AUTH_URL=https://api.staging.snapback.dev

# Production: production domain
# BETTER_AUTH_URL=https://api.snapback.dev

BETTER_AUTH_URL=http://localhost:3001

# Main application URL (used by OAuth callbacks)
# Development: localhost
# APP_URL=http://localhost:3001

# Staging: staging domain
# APP_URL=https://api.staging.snapback.dev

# Production: production domain
# APP_URL=https://api.snapback.dev

APP_URL=http://localhost:3001

# ================================
# Web Application Configuration
# ================================
# Frontend URLs (Next.js uses NEXT_PUBLIC_* prefix for client-side)

# Development
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
# NEXT_PUBLIC_APP_URL=http://console.localhost:3000
# NEXT_PUBLIC_DOCS_URL=http://docs.localhost:3000
# NEXT_PUBLIC_ROOT_DOMAIN=localhost

# Staging
# NEXT_PUBLIC_SITE_URL=https://staging.snapback.dev
# NEXT_PUBLIC_APP_URL=https://console.staging.snapback.dev
# NEXT_PUBLIC_DOCS_URL=https://docs.staging.snapback.dev
# NEXT_PUBLIC_ROOT_DOMAIN=staging.snapback.dev

# Production
# NEXT_PUBLIC_SITE_URL=https://snapback.dev
# NEXT_PUBLIC_APP_URL=https://console.snapback.dev
# NEXT_PUBLIC_DOCS_URL=https://docs.snapback.dev
# NEXT_PUBLIC_ROOT_DOMAIN=snapback.dev

NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://console.localhost:3000
NEXT_PUBLIC_DOCS_URL=http://docs.localhost:3000
NEXT_PUBLIC_ROOT_DOMAIN=localhost

# ================================
# OAuth Providers
# ================================
# GitHub OAuth Application
# Create at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# Google OAuth Application
# Create at: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ================================
# Email Service (Resend)
# ================================
# Email sending for auth flows, notifications
# Get key from: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key_here

# ================================
# Security & CAPTCHA
# ================================
# Cloudflare Turnstile for bot protection
# Create at: https://dash.cloudflare.com/
TURNSTILE_SITE_KEY=your_turnstile_site_key_here
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here

# ================================
# Payments (Stripe)
# ================================
# Stripe API keys for subscription management
# Get from: https://dashboard.stripe.com/apikeys

# Secret key (server-side only)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# Publishable key (safe for client-side)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# Webhook signing secret (from Dashboard > Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Price IDs for subscription plans
STRIPE_SOLO_MONTHLY_PRICE_ID=price_solo_monthly_id_here
STRIPE_TEAM_MONTHLY_PRICE_ID=price_team_monthly_id_here
STRIPE_ENTERPRISE_MONTHLY_PRICE_ID=price_enterprise_monthly_id_here

# ================================
# Monitoring & Observability
# ================================

# PostHog Analytics
# Get from: https://posthog.com/
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_key_here
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Google Analytics
# Create at: https://analytics.google.com/
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G_your_analytics_id_here

# Sentry Error Tracking
# Create at: https://sentry.io/
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn_here
SENTRY_AUTH_TOKEN=your_sentry_auth_token_here
SENTRY_ORG=your_sentry_org_here
SENTRY_PROJECT=your_sentry_project_here

# ================================
# Logging Configuration
# ================================
# Log level: debug, info, warn, error
# Development: debug or info
# Staging: info
# Production: warn or error
LOG_LEVEL=info

# ================================
# Feature Flags
# ================================
# Enable/disable features based on environment
FEATURE_DEBUG_MODE=false
FEATURE_VERBOSE_LOGGING=false

# ================================
# Rate Limiting
# ================================
# Rate limiting configuration
# Disabled in development, enabled in staging/production
RATE_LIMIT_ENABLED=false
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ================================
# Timeouts (milliseconds)
# ================================
API_TIMEOUT_MS=30000
DATABASE_TIMEOUT_MS=10000

# ================================
# API Configuration
# ================================
# API port and host
PORT=3001
HOST=localhost

# ================================
# Rules Signing (SnapBack-specific)
# ================================
# Key for signing rule bundles (minimum 32 characters)
RULES_SIGNING_KEY=your-rules-signing-key-minimum-32-characters

# ================================
# Storage Configuration (Optional)
# ================================
# S3/Supabase for file uploads
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_REGION=us-east-1
NEXT_PUBLIC_AVATARS_BUCKET_NAME=avatars

# Supabase (alternative to S3)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ================================
# Third-Party Integrations (Optional)
# ================================

# OpenAI API
OPENAI_API_KEY=sk_your_openai_key_here

# HubSpot CRM
HUBSPOT_ACCESS_TOKEN=pat-na1-your-hubspot-access-token

# ================================
# Development/Testing Only
# ================================
# These should NOT be used in staging or production

# Enable test data seeding
SEED_TEST_DATA=false

# Mock external services
MOCK_AUTH_SERVICE=false
MOCK_PAYMENT_SERVICE=false
