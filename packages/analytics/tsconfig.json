{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"outDir": "./dist",
		"rootDir": "./src",
		"emitDeclarationOnly": true,
		"composite": false,
		"incremental": false,
		"tsBuildInfoFile": "./dist/.tsbuildinfo",
		"typeRoots": ["./types", "./node_modules/@types"]
	},
	"include": ["src/**/*.ts", "types/**/*.d.ts"],
	"exclude": ["node_modules", "dist", "build"]
}
