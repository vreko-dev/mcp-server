{
	"extends": "@snapback/tsconfig/package",
	"compilerOptions": {
		"outDir": "./dist",
		"rootDir": "./src",
		"types": [],
		"tsBuildInfoFile": "./dist/.tsbuildinfo",
		"declaration": true,
		"declarationMap": true
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist", "dist-types", "tests", "src/legacy"]
}
