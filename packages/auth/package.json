{
	"name": "@snapback/auth",
	"version": "0.0.0",
	"dependencies": {
		"@node-rs/argon2": "catalog:",
		"@snapback/config": "workspace:*",
		"@snapback/contracts": "workspace:*",
		"@snapback/infrastructure": "workspace:*",
		"@snapback/integrations": "workspace:*",
		"@snapback/platform": "workspace:*",
		"@types/bcrypt": "catalog:",
		"bcrypt": "catalog:",
		"better-auth": "catalog:",
		"cookie": "^0.7.2",
		"drizzle-orm": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"@snapback/tsconfig": "workspace:*",
		"@types/cookie": "^0.5.1",
		"@types/node": "catalog:",
		"@vitest/coverage-v8": "catalog:",
		"tsup": "catalog:",
		"vitest": "catalog:"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./client": {
			"types": "./dist/client.d.ts",
			"default": "./dist/client.js"
		},
		"./auth": {
			"types": "./dist/auth.d.ts",
			"default": "./dist/auth.js"
		},
		"./lib/audit": {
			"types": "./dist/lib/audit.d.ts",
			"default": "./dist/lib/audit.js"
		},
		"./lib/helper": {
			"types": "./dist/lib/helper.d.ts",
			"default": "./dist/lib/helper.js"
		},
		"./lib/organization": {
			"types": "./dist/lib/organization.d.ts",
			"default": "./dist/lib/organization.js"
		},
		"./lib/tier-utils": {
			"types": "./dist/lib/tier-utils.d.ts",
			"default": "./dist/lib/tier-utils.js"
		}
	},
	"license": "UNLICENSED",
	"main": "./dist/index.js",
	"private": true,
	"scripts": {
		"build": "tsup && tsc --build --force",
		"migrate": "dotenv -e ../../.env.local -- pnpm dlx @better-auth/cli@latest generate --config ./auth.ts --output ../database/prisma/schema.prisma",
		"postbuild": "echo 'Auth package built successfully'",
		"test": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:watch": "vitest watch",
		"type-check": "tsc --noEmit"
	},
	"type": "module",
	"types": "./dist/index.d.ts"
}
