// Redis key structure for SnapBack
const REDIS_KEYS = {
  // Token validation cache (5min TTL)
  tokenCache: (hash: string) => `token:${hash}`,

  // Rate limiting (token bucket)
  rateLimit: (key: string) => `rate:${key}`,

  // Feature flag cache
  featureFlags: (userId: string) => `flags:${userId}`,

  // Session data (ephemeral)
  session: (sessionId: string) => `session:${sessionId}`,

