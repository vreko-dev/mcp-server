# ============================================
# Docker Development Environment Configuration
# ============================================
# This file contains Docker-specific environment variables
# DO NOT commit real credentials - use .env.docker.local for sensitive data

# ============================================
# Database Configuration
# ============================================
POSTGRES_DB=snapback
POSTGRES_USER=snapback
POSTGRES_PASSWORD=your_secure_database_password_here

# Database URL (internal Docker network)
DATABASE_URL=postgresql://snapback:your_secure_database_password_here@postgres:5432/snapback

# ============================================
# Redis Configuration
# ============================================
REDIS_URL=redis://redis:6379

# ============================================
# Authentication Configuration
# ============================================
# Better Auth secret (minimum 32 characters)
BETTER_AUTH_SECRET=your_super_secure_auth_secret_min_32_chars
BETTER_AUTH_URL=http://api.snapback.dev:8080

# ============================================
# Application URLs (Docker network)
# ============================================
# API Service (port 8080)
API_URL=http://api:8080
NEXT_PUBLIC_API_URL=http://api.snapback.dev:8080

# Web App (external port 4000, internal 3000)
WEB_URL=http://web:3000
NEXT_PUBLIC_WEB_URL=http://snapback.dev:4000

# Docs Site (external port 4001, internal 3000)
# Note: Docs deployed to Vercel in production, Docker for local dev only
DOCS_URL=http://docs:3000
NEXT_PUBLIC_DOCS_URL=http://docs.snapback.dev:4001

# Note: MCP server is now a library in packages/mcp, used by the CLI

# ============================================
# Development Settings
# ============================================
NODE_ENV=development
NEXT_TELEMETRY_DISABLED=1

# ============================================
# CORS Configuration
# ============================================
CORS_ORIGIN=http://snapback.dev,http://console.snapback.dev,http://docs.snapback.dev,http://api.snapback.dev,http://mcp.snapback.dev

# ============================================
# Email Service (MailHog for development)
# ============================================
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@snapback.dev

# ============================================
# OAuth Providers (Optional)
# ============================================
# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ============================================
# Email Service Providers (Production)
# ============================================
# Resend (Recommended)
RESEND_API_KEY=your_resend_api_key

# Plunk
PLUNK_API_KEY=your_plunk_api_key

# Postmark
POSTMARK_API_KEY=your_postmark_api_key

# Mailgun
MAILGUN_API_KEY=your_mailgun_api_key
MAILGUN_DOMAIN=your_mailgun_domain

# ============================================
# Storage Configuration
# ============================================
# S3 Compatible Storage
S3_ACCESS_KEY_ID=your_s3_access_key_id
S3_SECRET_ACCESS_KEY=your_s3_secret_access_key
S3_BUCKET_NAME=snapback-uploads
S3_REGION=us-east-1
S3_ENDPOINT=https://s3.amazonaws.com

# ============================================
# Payment Providers
# ============================================
# Stripe
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# ============================================
# AI Configuration (Optional)
# ============================================
OPENAI_API_KEY=your_openai_api_key

# ============================================
# Analytics & Monitoring (Optional)
# ============================================
# Google Analytics ID (starts with G-)
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=

# Sentry DSN (for error tracking) - Backend
SENTRY_DSN=
DISABLE_SENTRY=false

# Sentry DSN (for error tracking) - Frontend
NEXT_PUBLIC_SENTRY_DSN=

# PostHog configuration (for product analytics)
NEXT_PUBLIC_POSTHOG_KEY=

# ============================================
# Monitoring & Observability Stack
# ============================================
# These services are automatically available in docker-compose.holistic.yml:
# - Prometheus (metrics): http://localhost:9090
# - Grafana (dashboards): http://localhost:4002 (admin/admin)
# - Jaeger (tracing): http://localhost:16686
# - Redis Insight (cache): http://localhost:8001

# Jaeger Configuration (for distributed tracing)
JAEGER_AGENT_HOST=jaeger
JAEGER_AGENT_PORT=6831
JAEGER_SAMPLER_TYPE=const
JAEGER_SAMPLER_PARAM=1

# Prometheus Metrics
PROMETHEUS_PUSHGATEWAY_URL=http://prometheus-pushgateway:9091

# OpenTelemetry Configuration
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc

# ============================================
# Development Tools
# ============================================
# Prisma Studio port
PRISMA_STUDIO_PORT=5555

# Mailhog ports (for email testing)
MAILHOG_WEB_PORT=8025
MAILHOG_SMTP_PORT=1025

# Debug ports for Node.js debugging
DEBUG_PORT=9229
