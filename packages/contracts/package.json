{
  "name": "@snapback/contracts",
  "description": "Type definitions and contracts for SnapBack",
  "version": "0.2.1",
  "license": "Apache-2.0",
  "author": "SnapBack Team",
  "repository": {
    "type": "git",
    "url": "https://github.com/snapback-dev.git",
    "directory": "packages/contracts"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "catalog:",
    "eventemitter2": "catalog:",
    "nanoid": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "diff": "catalog:",
    "dotenv": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./events": {
      "types": "./dist/events/index.d.ts",
      "import": "./dist/events/index.js",
      "require": "./dist/events/index.cjs"
    },
    "./events/core": {
      "types": "./dist/events/core.d.ts",
      "import": "./dist/events/core.js",
      "require": "./dist/events/core.cjs"
    },
    "./events/legacy": {
      "types": "./dist/events/legacy.d.ts",
      "import": "./dist/events/legacy.js",
      "require": "./dist/events/legacy.cjs"
    },
    "./types/snapshot": {
      "types": "./dist/types/snapshot.d.ts",
      "import": "./dist/types/snapshot.js",
      "require": "./dist/types/snapshot.cjs"
    },
    "./session": {
      "types": "./dist/session.d.ts",
      "import": "./dist/session.js",
      "require": "./dist/session.cjs"
    },
    "./id-generator": {
      "types": "./dist/id-generator.d.ts",
      "import": "./dist/id-generator.js",
      "require": "./dist/id-generator.cjs"
    },
    "./observability": {
      "types": "./dist/observability/index.d.ts",
      "import": "./dist/observability/index.js",
      "require": "./dist/observability/index.cjs"
    },
    "./eventBus/emitter": {
      "types": "./dist/eventBus.emitter.d.ts",
      "import": "./dist/eventBus.emitter.js",
      "require": "./dist/eventBus.emitter.cjs"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/events/core.d.ts",
        "import": "./dist/events/core.js",
        "require": "./dist/events/core.cjs"
      },
      "./events": {
        "types": "./dist/events/index.d.ts",
        "import": "./dist/events/index.js",
        "require": "./dist/events/index.cjs"
      },
      "./events/core": {
        "types": "./dist/events/core.d.ts",
        "import": "./dist/events/core.js",
        "require": "./dist/events/core.cjs"
      },
      "./events/legacy": {
        "types": "./dist/events/legacy.d.ts",
        "import": "./dist/events/legacy.js",
        "require": "./dist/events/legacy.cjs"
      },
      "./types/snapshot": {
        "types": "./dist/types/snapshot.d.ts",
        "import": "./dist/types/snapshot.js",
        "require": "./dist/types/snapshot.cjs"
      },
      "./session": {
        "types": "./dist/session.d.ts",
        "import": "./dist/session.js",
        "require": "./dist/session.cjs"
      },
      "./id-generator": {
        "types": "./dist/id-generator.d.ts",
        "import": "./dist/id-generator.js",
        "require": "./dist/id-generator.cjs"
      },
      "./observability": {
        "types": "./dist/observability/index.d.ts",
        "import": "./dist/observability/index.js",
        "require": "./dist/observability/index.cjs"
      },
      "./eventBus/emitter": {
        "types": "./dist/eventBus.emitter.d.ts",
        "import": "./dist/eventBus.emitter.js",
        "require": "./dist/eventBus.emitter.cjs"
      }
    }
  },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "scripts": {
    "build": "node scripts/build.contracts.mjs",
    "check": "biome check .",
    "format": "biome format --write .",
    "generate": "echo '[contracts] generate is handled by build script'",
    "lint": "biome lint .",
    "lint:fix": "biome lint --fix .",
    "openapi": "node scripts/generate-openapi.mjs || echo \"openapi placeholder\"",
    "test": "vitest run",
    "type-check": "tsc --noEmit"
  },
  "type": "module",
  "types": "dist/index.d.ts"
}
