### Token Flow by Component

```typescript
// 1. Web Portal Login (OAuth)
// User clicks "Sign in with GitHub"
POST /api/auth/github/callback
â†’ Better Auth creates session
â†’ Set httpOnly cookie: snapback_session
â†’ Cookie includes: { userId, orgId?, sessionId }

// 2. Extension Authentication
// Extension opens browser to web portal
GET /auth/extension-grant?extensionId={uuid}
â†’ User already logged in (has session cookie)
â†’ Generate one-time grant code
â†’ Extension polls for grant approval
â†’ Return: { apiKey: "sk_live_...", expiresAt, userId }

// 3. API Key Usage (All Components)
// Every component uses same pattern
headers: {
  'Authorization': `Bearer ${apiKey}`,
  'X-Client-Type': 'extension|cli|sdk|mcp',
  'X-Client-Version': '1.2.5'
}

// 4. Token Validation (Centralized)
// All API calls validate through same middleware
async function validateToken(token: string): Promise<TokenContext> {
  // Check Redis cache first (sub-millisecond)
  const cached = await redis.get(`token:${hashToken(token)}`);
  if (cached) return JSON.parse(cached);

  // Validate against DB
  const result = await KeysDb.verifyKey(token);

  // Cache for 5 minutes
  await redis.setex(`token:${hashToken(token)}`, 300, JSON.stringify(result));

  return result;
}
```

### Session Identity Propagation

```typescript
// TokenContext passed to all components
interface TokenContext {
  // Identity
  userId: string;
  orgId?: string;
  teamId?: string;

  // Access
  tier: 'free' | 'pro' | 'enterprise';
  permissions: Permission[];

  // Rate limiting
  rateLimitKey: string;
  requestsRemaining: number;

  // Telemetry (anonymized)
  anonymousId: string;  // For PostHog, never userId

  // Audit
  sessionId: string;
  clientType: 'extension' | 'cli' | 'sdk' | 'mcp' | 'web';
  clientVersion: string;
}
