# .ctx v1
# machine-readable project context
# format: domain.key=value | !blocker | >priority | @ref

[id]
t=code-protection
p=sprint
d=demo-crit

[lim]
# @ext constraints
_eb<2M
_ea<500
_es<100
_em<200
# @web constraints
_wf<1.8
_wl<2.5
_wj<500

[arc]
_pr=meta-only
_zs=1
_ts=strict

[blk]
!_ts:32
!_eb:11M
!_an:7>1
!_ev:127>60

[dec]
>demo-unblock
>perf-budget
>debt-plan
>privacy

[stk]
tr|pn|nx14|vsc99|dz|pg|ph|or|vi|pw

[qg]
_ts=0|cov>80|perf|bun|con=0

[kdec]
_cl=dbscan
_df=jsdiff:sm,dmp:lg
_an=ph
_gd=cascade

[ref]
@a=.claude/ctx/a/
@s=.claude/ctx/s/
ext=@a/ext.md
web=@a/web.md
mcp=@a/mcp.md
perf=@a/perf.md
test=@a/test.md
evt=@a/evt.md
db=@a/db.md
impl=@s/impl.md
cli=@s/cli.md

[wf]
feat=audit>design>tdd>perf>sec>doc
fix=repro>root>min>reg
refac=meas>phase>cov>flag>val

[proto]
opt=2-3
ref=file:line
risk=explicit
size=smLxl+20

#EOF
