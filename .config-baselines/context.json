{
	"$schema": "./context.schema.json",
	"version": "1.0.0",
	"generated": null,
	"meta": {
		"id": "snapback",
		"type": "code-protection",
		"phase": "sprint",
		"priority": "demo-critical"
	},
	"constraints": {
		"extension": {
			"bundle": { "max": 2, "unit": "MB", "key": "_eb", "current": 11 },
			"activation": { "max": 500, "unit": "ms", "key": "_ea" },
			"save": { "max": 100, "unit": "ms", "key": "_es" },
			"memory": { "max": 200, "unit": "MB", "key": "_em" }
		},
		"web": {
			"fcp": { "max": 1.8, "unit": "s", "key": "_wf" },
			"lcp": { "max": 2.5, "unit": "s", "key": "_wl" },
			"jsBundle": { "max": 500, "unit": "KB", "key": "_wj" }
		}
	},
	"blockers": [
		{ "key": "_ts", "label": "typescript-errors", "current": 32, "target": 0 },
		{ "key": "_eb", "label": "bundle-size", "current": "11MB", "target": "2MB" },
		{ "key": "_an", "label": "analytics-providers", "current": 7, "target": 1 },
		{ "key": "_ev", "label": "event-systems", "current": 127, "target": 60 }
	],
	"architecture": {
		"privacy": "metadata-only",
		"zeroShortcuts": true,
		"typeStrict": true
	},
	"decisions": {
		"priority": ["demo-unblock", "perf-budget", "debt-plan", "privacy"],
		"made": {
			"clustering": "dbscan",
			"diff": { "small": "jsdiff", "large": "diff-match-patch" },
			"analytics": "posthog",
			"gdpr": "cascade-delete"
		}
	},
	"stack": {
		"monorepo": "turborepo",
		"packageManager": "pnpm",
		"framework": "next14",
		"extension": "vscode-1.99",
		"orm": "drizzle",
		"database": "postgres",
		"analytics": "posthog",
		"rpc": "orpc",
		"testing": ["vitest", "playwright"]
	},
	"quality": {
		"typescript": { "errors": 0 },
		"coverage": { "min": 80 },
		"perfBudgets": true,
		"bundleValidation": true,
		"consoleErrors": 0
	},
	"workflows": {
		"feature": ["audit", "design", "tdd", "perf", "security", "docs"],
		"bugfix": ["reproduce", "root-cause", "minimal-fix", "regression"],
		"refactor": ["measure", "phase", "coverage", "flag", "validate"]
