{
  "name": "@snapback/engine",
  "version": "0.1.0",
  "description": "Core SnapBack engine - transport agnostic",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./signals": {
      "import": "./dist/signals/index.js",
      "types": "./dist/signals/index.d.ts"
    },
    "./runtime": {
      "import": "./dist/runtime/index.js",
      "types": "./dist/runtime/index.d.ts"
    },
    "./validators": {
      "import": "./dist/validators/index.js",
      "types": "./dist/validators/index.d.ts"
    },
    "./transports/mcp": {
      "import": "./dist/transports/mcp.js",
      "types": "./dist/transports/mcp.d.ts"
    },
    "./transports/http": {
      "import": "./dist/transports/http.js",
      "types": "./dist/transports/http.d.ts"
    },
    "./transports/cli": {
      "import": "./dist/transports/cli.js",
      "types": "./dist/transports/cli.d.ts"
    }
  },
  "scripts": {
    "build": "tsup && node ../../scripts/build-utils/add-js-extensions.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@snapback/contracts": "workspace:*",
    "esprima": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@snapback/config": "workspace:*",
    "@types/esprima": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
