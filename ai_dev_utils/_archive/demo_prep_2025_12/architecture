## Component Integration Patterns

### Extension â†” API Communication

```typescript
// Extension API client (used by VS Code extension)
class SnapBackAPIClient {
  constructor(
    private apiKey: string,
    private baseUrl: string = 'https://api.snapback.dev'
  ) {}

  // All requests include identity context
  private async request<T>(
    endpoint: string,
    options: RequestInit = {}
  ): Promise<T> {
    const response = await fetch(`${this.baseUrl}${endpoint}`, {
      ...options,
      headers: {
        'Authorization': `Bearer ${this.apiKey}`,
        'X-Client-Type': 'extension',
        'X-Client-Version': EXTENSION_VERSION,
        'Content-Type': 'application/json',
        ...options.headers,
      },
    });

    if (!response.ok) {
      const error = await response.json();
      throw new SnapBackAPIError(error);
    }

    return response.json();
  }

  // Server-side features (IP-protected)
  async analyzeRisk(diff: string, context: RiskContext): Promise<RiskAnalysis> {
    return this.request('/v1/analyze/risk', {
      method: 'POST',
      body: JSON.stringify({ diff, context }),
    });
  }

  async getSmartGrouping(snapshots: string[]): Promise<GroupingResult> {
    return this.request('/v1/analyze/grouping', {
      method: 'POST',
      body: JSON.stringify({ snapshotIds: snapshots }),
    });
  }

  async validateRollback(snapshotId: string): Promise<RollbackValidation> {
    return this.request(`/v1/snapshots/${snapshotId}/validate-rollback`);
  }
}
```

### MCP Server â†” Backend Proxy

```typescript
// MCP server proxies to backend for IP-protected features
class MCPBackendProxy {
  constructor(private apiKey: string) {}

  async handleToolCall(tool: string, args: unknown): Promise<ToolResult> {
    // Free tier tools run locally (basic logic)
    if (FREE_TIER_TOOLS.includes(tool)) {
      return this.executeLocal(tool, args);
    }

    // Pro tier tools proxy to backend (IP-protected)
    return this.executeRemote(tool, args);
  }

  private async executeRemote(tool: string, args: unknown): Promise<ToolResult> {
    const response = await fetch('https://api.snapback.dev/v1/mcp/execute', {
      method: 'POST',
      headers: {
        'Authorization': `Bearer ${this.apiKey}`,
        'X-Client-Type': 'mcp',
      },
      body: JSON.stringify({ tool, args }),
    });

    return response.json();
  }
}
```

