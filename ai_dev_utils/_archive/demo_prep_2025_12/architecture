## Infrastructure Architecture

### PostgreSQL Schema (Privacy-First)

```sql
-- Core user identity (Better Auth compatible)
CREATE TABLE "user" (
  id TEXT PRIMARY KEY,
  email TEXT UNIQUE NOT NULL,
  name TEXT,
  image TEXT,
  email_verified BOOLEAN DEFAULT false,
  created_at TIMESTAMP DEFAULT NOW(),
  updated_at TIMESTAMP DEFAULT NOW()
);

-- Organization structure
CREATE TABLE organization (
  id TEXT PRIMARY KEY,
  name TEXT NOT NULL,
  slug TEXT UNIQUE NOT NULL,
  logo TEXT,
  tier subscription_tier DEFAULT 'free',
  created_at TIMESTAMP DEFAULT NOW()
);

-- API Keys (secure storage)
CREATE TABLE api_keys (
  id TEXT PRIMARY KEY,
  user_id TEXT REFERENCES "user"(id) ON DELETE CASCADE,
  org_id TEXT REFERENCES organization(id) ON DELETE CASCADE,
  key_prefix TEXT NOT NULL,  -- "sk_live_abc" (for display)
  key_hash TEXT NOT NULL,    -- SHA-256 of full key
  name TEXT NOT NULL,
  permissions JSONB DEFAULT '[]',
  last_used_at TIMESTAMP,
  request_count INTEGER DEFAULT 0,
  expires_at TIMESTAMP,
  revoked_at TIMESTAMP,
  created_at TIMESTAMP DEFAULT NOW()
);

-- Snapshot metadata (privacy-first: NO code content)
CREATE TABLE snapshots (
  id TEXT PRIMARY KEY,
  user_id TEXT REFERENCES "user"(id) ON DELETE CASCADE,
  api_key_id TEXT REFERENCES api_keys(id) ON DELETE SET NULL,

  -- Metadata only
  trigger TEXT NOT NULL,  -- 'auto' | 'manual' | 'ai-detected'
  file_count INTEGER NOT NULL,
  total_bytes INTEGER NOT NULL,
  ai_detected BOOLEAN DEFAULT false,
  ai_tool TEXT,  -- 'cursor' | 'copilot' | 'claude'
  ai_confidence REAL,

  -- Optional cloud backup (explicit opt-in)
  cloud_backup_enabled BOOLEAN DEFAULT false,
  storage_location TEXT,  -- S3 path if backed up

  created_at TIMESTAMP DEFAULT NOW()
);

-- Telemetry (anonymized, privacy-compliant)
CREATE TABLE telemetry_events (
  id TEXT PRIMARY KEY,
  anonymous_id TEXT NOT NULL,  -- PostHog distinct_id, never user_id
  event_type TEXT NOT NULL,
  properties JSONB NOT NULL,

  -- Sanitized (no PII)
  client_type TEXT NOT NULL,
  client_version TEXT NOT NULL,

  created_at TIMESTAMP DEFAULT NOW()
) PARTITION BY RANGE (created_at);

-- Retention policy (GDPR compliance)
CREATE TABLE retention_config (
  table_name TEXT PRIMARY KEY,
  retention_days INTEGER NOT NULL,
  last_cleanup TIMESTAMP
);

-- Indexes for performance
CREATE INDEX idx_snapshots_user_created ON snapshots(user_id, created_at DESC);
CREATE INDEX idx_telemetry_anonymous_id ON telemetry_events(anonymous_id);
CREATE INDEX idx_api_keys_hash ON api_keys(key_hash);
```

