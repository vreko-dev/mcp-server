# SnapBack Auth Package - Environment Configuration Template
#
# Copy to .env.local, .env.staging, or .env.production
# For development: cp .env.example .env.local
#
# This package provides Better Auth integration for the SnapBack platform
#
# IMPORTANT: Never commit .env.local, .env.staging, .env.production
# Add to .gitignore: .env.local, .env.staging, .env.production

# ================================
# Environment Identification
# ================================
# Options: development | staging | production
NODE_ENV=development

# ================================
# Database Configuration
# ================================
# PostgreSQL connection for Better Auth
# Used for storing users, sessions, OAuth tokens, API keys

DATABASE_URL=postgresql://snapback:snapback@localhost:5432/snapback_dev
DIRECT_URL=postgresql://snapback:snapback@localhost:5432/snapback_dev

# ================================
# Better Auth Core Configuration
# ================================
# Secret key for signing tokens and sessions (minimum 32 characters)
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=dev-secret-minimum-32-characters-for-local-dev

# Better Auth service URL (where auth handlers are available)
BETTER_AUTH_URL=http://localhost:3001

# Application URL (for CORS and redirects)
APP_URL=http://localhost:3001

# ================================
# OAuth Providers
# ================================
# GitHub OAuth Application
# Create at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Google OAuth Application
# Create at: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ================================
# Email Service
# ================================
# Resend for sending emails (password reset, magic links, etc.)
# Get API key from: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key_here

# ================================
# Session Configuration
# ================================
# Session expiration time (seconds)
# Development: 7 days (604800)
# Staging: 7 days (604800)
# Production: 7 days (604800)
SESSION_EXPIRES_IN=604800

# Session update age (seconds) - refresh token when this old
# Default: 1 day (86400)
SESSION_UPDATE_AGE=86400

# ================================
# JWT Configuration
# ================================
# JWT algorithm (HS256, RS256, EdDSA)
JWT_ALGORITHM=HS256

# JWT expires in (seconds)
# Default: 15 minutes (900) for access tokens
JWT_EXPIRES_IN=900

# JWT issuer (your application)
JWT_ISSUER=snapback

# JWT audience (must match configured audiences in auth.ts)
# NOTE: This applies to general Better Auth JWT tokens (device auth flow)
# Other specialized tokens use different audiences:
#   - Extension tokens: "snapback-extension" (VSCode extension)
#   - Rules bundle tokens: "snapback-clients" (rules distribution)
JWT_AUDIENCE=vscode,mcp,cli

# ================================
# API Key Configuration
# ================================
# API key prefix (for identification)
API_KEY_PREFIX=sk_test_

# API key expires in (seconds)
# Default: 90 days (7776000)
API_KEY_EXPIRES_IN=7776000

# ================================
# Two-Factor Authentication (2FA)
# ================================
# Enable 2FA
ENABLE_2FA=true

# 2FA window time (seconds) - time window for TOTP validation
# Default: 30 seconds
TOTP_WINDOW=30

# ================================
# Password Policy
# ================================
# Minimum password length
PASSWORD_MIN_LENGTH=8

# Require uppercase letters
PASSWORD_REQUIRE_UPPERCASE=true

# Require lowercase letters
PASSWORD_REQUIRE_LOWERCASE=true

# Require numbers
PASSWORD_REQUIRE_NUMBERS=true

# Require special characters
PASSWORD_REQUIRE_SPECIAL_CHARS=true

# ================================
# Account Lockout Policy
# ================================
# Enable account lockout after failed login attempts
ENABLE_ACCOUNT_LOCKOUT=true

# Max failed login attempts before lockout
MAX_FAILED_ATTEMPTS=5

# Lockout duration (seconds)
LOCKOUT_DURATION=900  # 15 minutes

# ================================
# Email Verification
# ================================
# Require email verification during signup
REQUIRE_EMAIL_VERIFICATION=true

# Email verification expiration (seconds)
EMAIL_VERIFICATION_EXPIRES_IN=86400  # 24 hours

# ================================
# Password Reset
# ================================
# Password reset token expiration (seconds)
PASSWORD_RESET_EXPIRES_IN=3600  # 1 hour

# ================================
# Magic Link
# ================================
# Magic link expiration (seconds)
MAGIC_LINK_EXPIRES_IN=3600  # 1 hour

# ================================
# Logging
# ================================
# Log level: debug, info, warn, error
LOG_LEVEL=info

# Log authentication events
LOG_AUTH_EVENTS=true

# ================================
# Development/Testing Only
# ================================
# Skip email verification (for testing)
SKIP_EMAIL_VERIFICATION=false

# Allow weak passwords (for testing)
ALLOW_WEAK_PASSWORDS=false

# Mock email service (don't actually send emails)
MOCK_EMAIL_SERVICE=false

# Enable debug mode
DEBUG=false
