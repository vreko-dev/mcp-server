# pnpm Configuration for SnapBack Monorepo
# Follows best practices for native modules and build tool compatibility

# Use isolated (strict) node_modules by default for better dependency safety
node-linker=isolated

# Hoist build tools to virtual store for cross-package availability
# This ensures packages can access their declared dev dependencies
hoist-pattern[]=*typescript*
hoist-pattern[]=*tsup*
hoist-pattern[]=*esbuild*
hoist-pattern[]=*vitest*
hoist-pattern[]=*@vitest*
hoist-pattern[]=*better-sqlite3*
hoist-pattern[]=*bindings*
hoist-pattern[]=*prisma*
hoist-pattern[]=*biome*
hoist-pattern[]=*postcss*
hoist-pattern[]=*tailwindcss*

# Publicly hoist ONLY native modules that have binary compatibility issues
# Minimizes dependency visibility pollution
public-hoist-pattern[]=*better-sqlite3*
public-hoist-pattern[]=*bindings*
public-hoist-pattern[]=*prisma*

# Disable shameful hoisting - use proper dependency hoisting instead
shamefully-hoist=false

# Suppress warnings about non-executable bins from @types packages
ignore-scripts=false
