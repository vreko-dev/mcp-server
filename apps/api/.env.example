# SnapBack API Server - Environment Configuration Template
#
# Copy to .env.local, .env.staging, or .env.production
# For development: cp .env.example .env.local
#
# IMPORTANT: Never commit .env.local, .env.staging, .env.production
# Add to .gitignore: .env.local, .env.staging, .env.production

# ================================
# Environment Identification
# ================================
# Options: development | staging | production
NODE_ENV=development

# ================================
# Server Configuration
# ================================
# API server port (change per environment if needed)
# Development: 3001
# Staging: typically 443 (behind reverse proxy)
# Production: typically 443 (behind reverse proxy)
PORT=3001
HOST=0.0.0.0

# ================================
# Database Configuration
# ================================
# PostgreSQL connection strings
# IMPORTANT: Use DIRECT_URL for migrations (non-pooled connection)
# Use DATABASE_URL for application (pooled connection)

# Example patterns:
# postgresql://user:password@host:port/database
# postgresql://user:password@host:5432/database?sslmode=require

DATABASE_URL=postgresql://snapback:snapback@localhost:5432/snapback_dev
DIRECT_URL=postgresql://snapback:snapback@localhost:5432/snapback_dev

# ================================
# Redis Configuration
# ================================
# Redis instance for caching, sessions, rate limiting
# Format: redis://[:password]@host:port/[db]

REDIS_URL=redis://localhost:6379

# ================================
# Authentication (Better Auth)
# ================================
# Core authentication service configuration

# Secret key for JWT and session signing (minimum 32 characters)
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=dev-secret-minimum-32-characters-for-local-dev

# Better Auth service URL (where this service handles auth endpoints)
# Development: http://localhost:3001
# Staging: https://api.staging.snapback.dev
# Production: https://api.snapback.dev
BETTER_AUTH_URL=http://localhost:3001

# Main application URL (used for CORS, redirects, OAuth)
# Development: http://localhost:3001
# Staging: https://api.staging.snapback.dev
# Production: https://api.snapback.dev
APP_URL=http://localhost:3001

# Frontend application URL (for CORS and redirects from auth flows)
# Development: http://console.localhost:3000
# Staging: https://console.staging.snapback.dev
# Production: https://console.snapback.dev
NEXT_PUBLIC_APP_URL=http://console.localhost:3000

# ================================
# OAuth Providers
# ================================
# GitHub OAuth Application
# Create at: https://github.com/settings/developers
# Set Authorization callback URL to: {APP_URL}/auth/callback/github
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Google OAuth Application
# Create at: https://console.cloud.google.com/
# Set Authorized redirect URIs to: {APP_URL}/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ================================
# Email Service (Resend)
# ================================
# Email sending for password reset, magic links, notifications
# Get API key from: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key_here

# ================================
# Security & CAPTCHA
# ================================
# Cloudflare Turnstile for bot protection on auth endpoints
# Create at: https://dash.cloudflare.com/
# Required for: /auth/sign-up, /auth/sign-in, /auth/otp
TURNSTILE_SITE_KEY=your_turnstile_site_key
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# ================================
# Payments (Stripe)
# ================================
# Stripe API keys for subscription management
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ================================
# Monitoring & Analytics
# ================================
# PostHog for event tracking and analytics
# Get key from: https://posthog.com/
POSTHOG_API_KEY=phc_your_posthog_key_here

# Sentry for error tracking
# Create at: https://sentry.io/
# Set up project DSN
SENTRY_DSN=your_sentry_dsn_here

# ================================
# Logging Configuration
# ================================
# Log level: debug, info, warn, error
# Development: debug or info
# Staging: info
# Production: warn or error
LOG_LEVEL=debug

# ================================
# Feature Flags & Environment-Specific Settings
# ================================
# Enable detailed request/response logging
LOG_REQUESTS=true

# Enable SQL query logging
LOG_SQL_QUERIES=false

# ================================
# Rate Limiting
# ================================
# Rate limiting configuration
# NOTE: Auth endpoints have hardcoded limits in auth.ts:
#   - Sign-in: 3 attempts per 10 seconds
#   - Sign-up: 5 per minute
#   - Password reset: 3 per minute
# These variables control general API rate limiting
RATE_LIMIT_ENABLED=false
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ================================
# API Timeouts
# ================================
# Timeout for external API calls (milliseconds)
API_TIMEOUT_MS=30000

# Timeout for database queries (milliseconds)
DATABASE_TIMEOUT_MS=10000

# ================================
# Rules Engine (SnapBack-specific)
# ================================
# Key for signing rule bundles (minimum 32 characters)
# Generate with: openssl rand -base64 32
RULES_SIGNING_KEY=your-rules-signing-key-minimum-32-characters

# ================================
# CORS Configuration
# ================================
# NOTE: CORS is currently configured via getBaseUrl() from @snapback/config package
# in apps/api/src/index.ts, not from this environment variable.
# Comma-separated list of allowed origins (for reference/future use)
# Development: http://localhost:3000,http://console.localhost:3000
# Staging: https://staging.snapback.dev,https://console.staging.snapback.dev
# Production: https://snapback.dev,https://console.snapback.dev
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://console.localhost:3000

# ================================
# Development/Testing Only
# ================================
# These should be false in staging and production

# Disable authentication for testing
SKIP_AUTH=false

# Seed database with test data on startup
SEED_TEST_DATA=false

# Enable verbose debugging
DEBUG=false
