{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "Discovery State Schema",
	"type": "object",
	"required": ["phase", "passes_completed", "findings", "duplications", "opportunities"],
	"properties": {
		"phase": {
			"const": "discovery"
		},
		"passes_completed": {
			"type": "array",
			"items": {
				"type": "string",
				"pattern": "^(SYS_DET|SYS_CONFIG|SYS_SCHEMA|SYS_PIONEER)$"
			}
		},
		"findings": {
			"type": "object",
			"patternProperties": {
				"^F_": {
					"type": "array",
					"items": {
						"type": "object",
						"required": ["file", "line", "usage"],
						"properties": {
							"file": {
								"type": "string"
							},
							"line": {
								"type": "integer"
							},
							"usage": {
								"type": "string"
							},
							"context": {
								"type": "string"
							}
						}
					}
				}
			}
		},
		"duplications": {
			"type": "object",
			"patternProperties": {
				"^D_": {
					"type": "object",
					"required": ["sources", "conflict", "recommendation"],
					"properties": {
						"sources": {
							"type": "array",
							"items": {
								"type": "string"
							}
						},
						"conflict": {
							"type": "string"
						},
						"recommendation": {
							"type": "string"
						},
						"priority": {
							"type": "string",
							"enum": ["P0", "P1", "P2"]
						}
					}
				}
			}
		},
		"opportunities": {
			"type": "object",
			"patternProperties": {
				"^OP_": {
					"type": "object",
					"required": ["priority", "impact", "risk", "estimated_loc", "files_affected", "tests_required"],
					"properties": {
						"priority": {
							"type": "string",
							"enum": ["P0", "P1", "P2"]
						},
						"impact": {
							"type": "string",
							"enum": ["High", "Medium", "Low"]
						},
						"risk": {
							"type": "string",
							"enum": ["High", "Medium", "Low"]
						},
						"estimated_loc": {
							"type": "integer"
						},
						"files_affected": {
							"type": "integer"
						},
						"tests_required": {
							"type": "integer"
						},
						"description": {
							"type": "string"
						},
						"approved": {
							"type": "boolean"
						}
					}
				}
			}
		}
	}
}
