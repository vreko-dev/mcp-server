# Web Application Configuration
# Copy this file to .env.local and update with your credentials

# Site Configuration (Local Development)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://console.localhost:3000"
NEXT_PUBLIC_DOCS_URL="http://docs.localhost:3000"
NEXT_PUBLIC_ROOT_DOMAIN="localhost"

# Production values:
# NEXT_PUBLIC_SITE_URL="https://snapback.dev"
# NEXT_PUBLIC_APP_URL="https://console.snapback.dev"
# NEXT_PUBLIC_DOCS_URL="https://docs.snapback.dev"
# NEXT_PUBLIC_ROOT_DOMAIN="snapback.dev"

# Database
# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/snapback"

# Payments (Stripe)
# Stripe Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"
# Plan Price IDs - get these from Stripe Dashboard > Products
STRIPE_SOLO_MONTHLY_PRICE_ID="price_solo_monthly_id"
STRIPE_TEAM_MONTHLY_PRICE_ID="price_team_monthly_id"
STRIPE_ENTERPRISE_MONTHLY_PRICE_ID="price_enterprise_monthly_id"

# Analytics
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=""
NEXT_PUBLIC_POSTHOG_KEY="phc_pxblmsZJOJHYMjgyCIGRfUDR21SLGh9QcuNkDK7PQwN"
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# Authentication (Better Auth)
# ⚠️ OAuth secrets MUST be in packages/api/.env (server-side only)
# Client IDs only (public, safe for client-side):
NEXT_PUBLIC_GITHUB_CLIENT_ID="your-github-oauth-app-client-id"
NEXT_PUBLIC_GOOGLE_CLIENT_ID="your-google-oauth-client-id.apps.googleusercontent.com"

# Server-only env vars (packages/api/.env):
# BETTER_AUTH_SECRET="your-secret-key-here-use-openssl-rand-base64-32"
# GITHUB_CLIENT_SECRET="your-github-oauth-app-client-secret"
# GOOGLE_CLIENT_SECRET="your-google-oauth-client-secret"

# Storage (Supabase)
# Supabase Project Settings: https://app.supabase.com/project/_/settings/api
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_PUBLISHABLE_DEFAULT_KEY="your-anon-public-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_ENDPOINT=""
S3_REGION=""
NEXT_PUBLIC_AVATARS_BUCKET_NAME="avatars"

# Monitoring (Sentry)
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# Product Price IDs
NEXT_PUBLIC_PRICE_ID_PRO_MONTHLY=""
NEXT_PUBLIC_PRICE_ID_PRO_YEARLY=""
NEXT_PUBLIC_PRICE_ID_LIFETIME=""

# AI Services (Optional)
OPENAI_API_KEY=""

# Email Service (Resend)
# Resend Dashboard: https://resend.com/api-keys
RESEND_API_KEY="re_your_resend_api_key"

# CRM Integration (HubSpot)
# HubSpot Private Apps: https://app.hubspot.com/settings/apps/private-apps
# Required scopes: crm.objects.contacts.read, crm.objects.contacts.write
HUBSPOT_ACCESS_TOKEN="pat-na1-your-hubspot-access-token"

# Redis
REDIS_URL="redis://default:password@host:port"
