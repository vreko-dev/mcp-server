# SnapBack Better Auth - Environment Variables Template
# Copy this to .env.local for development
# Add to Vercel/deployment platform for production

# ==============================================================================
# CORE CONFIGURATION
# ==============================================================================

# Better Auth Base URL (production should be https://api.snapback.dev)
BETTER_AUTH_URL=https://api.snapback.dev
# Or for development:
# BETTER_AUTH_URL=http://localhost:3000

# Better Auth Secret (generate with: openssl rand -base64 32)
BETTER_AUTH_SECRET=your-256-bit-secret-here

# App URL (main frontend)
APP_URL=https://snapback.dev
# Or for development:
# APP_URL=http://localhost:3000

# Node Environment
NODE_ENV=production
# Or for development:
# NODE_ENV=development

# ==============================================================================
# DATABASE
# ==============================================================================

# Postgres connection string
DATABASE_URL=postgres://user:password@host:5432/snapback

# ==============================================================================
# OAUTH PROVIDERS
# ==============================================================================

# GitHub OAuth (https://github.com/settings/developers)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ==============================================================================
# EMAIL PROVIDER (choose one)
# ==============================================================================

# Resend (https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxx

# Or SendGrid (https://sendgrid.com/docs/ui/account-and-settings/api-keys/)
# SENDGRID_API_KEY=SG.xxxxxxxxxxxx

# ==============================================================================
# CAPTCHA (Cloudflare Turnstile)
# ==============================================================================

# Turnstile (https://dash.cloudflare.com/turnstile)
CAPTCHA_SITE_KEY=0x4xxxxxxxxxxxxxxxxx
CAPTCHA_SECRET_KEY=0x4xxxxxxxxxxxxxxxxx

# ==============================================================================
# JWT FOR TOOLS (VSCode/CLI/MCP)
# ==============================================================================

# Generate RS256 key pair:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem

# Private key (include full BEGIN/END markers)
BETTER_AUTH_JWT_PRIVATE_PEM="-----BEGIN PRIVATE KEY-----
MIIEvQIBADANBgkqhkiG9w0BAQEFAASCBKcwggSjAgEAAoIBAQC...
...your private key here...
-----END PRIVATE KEY-----"

# Public key (include full BEGIN/END markers)
BETTER_AUTH_JWT_PUBLIC_PEM="-----BEGIN PUBLIC KEY-----
MIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEAtX...
...your public key here...
-----END PUBLIC KEY-----"

# ==============================================================================
# POSTHOG ANALYTICS
# ==============================================================================

# PostHog (https://posthog.com/docs/api/overview)
POSTHOG_API_KEY=phc_xxxxxxxxxxxx
POSTHOG_HOST=https://us.posthog.com
# Or for EU:
# POSTHOG_HOST=https://eu.posthog.com
# Or for self-hosted:
# POSTHOG_HOST=https://your-posthog-instance.com

# ==============================================================================
# STRIPE PAYMENTS
# ==============================================================================

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx  # Use sk_live_ for production
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# ==============================================================================
# FEATURE FLAGS
# ==============================================================================

# Enforce passkeys for all roles on sensitive actions
FEATURE_PASSKEY_ENFORCE_ALL=true

# Enable adaptive Turnstile challenges
FEATURE_TURNSTILE_ADAPTIVE=true

# ==============================================================================
# AUTH CONFIGURATION
# ==============================================================================

# Step-up authentication window (seconds)
AUTH_STEPUP_WINDOW_SEC=300  # 5 minutes

# Turnstile failure threshold (failures before challenge required)
TURNSTILE_FAILURE_THRESHOLD=5

# Turnstile failure window (milliseconds)
TURNSTILE_WINDOW_MS=10000  # 10 seconds

# ==============================================================================
# SIGNUP CONTROL
# ==============================================================================

# Enable public signup (set to "false" for invitation-only)
ENABLE_SIGNUP=false

# ==============================================================================
# OPTIONAL: REDIS (for production rate limiting)
# ==============================================================================

# Upstash Redis (https://upstash.com/docs/redis)
# UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-redis-token

# ==============================================================================
# OPTIONAL: SENTRY (error tracking)
# ==============================================================================

# Sentry (https://sentry.io/settings/account/api/auth-tokens/)
# SENTRY_DSN=https://xxxx@sentry.io/xxxxx
# SENTRY_AUTH_TOKEN=sntrys_xxxxx

# ==============================================================================
# OPTIONAL: LOGGING
# ==============================================================================

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# ==============================================================================
# NOTES
# ==============================================================================

# Cross-Subdomain Cookies:
#   In production, cookies are set with Domain=.snapback.dev
#   This allows sessions to work across snapback.dev and app.snapback.dev

# JWT for Tools:
#   Web uses session cookies (no JWT)
#   VSCode/CLI/MCP use 15-minute RS256 JWT tokens
#   JWKS endpoint: ${BETTER_AUTH_URL}/api/auth/jwks
#   JWKS rotation: every 14 days with 48h overlap

# API Keys:
#   Hashed with argon2id (memory=64MB, time=3, parallel=4)
#   Revealed once on creation
#   Prefix: sb_live_ or sb_test_

# Step-Up Auth:
#   Required for billing, API key reveal, org changes
#   300s (5 min) validity window
#   Methods: passkey > TOTP > password

# Passkey Enforcement:
#   All roles must have passkey for ultra-sensitive actions
#   TOTP fallback allowed once, then enrollment required

# Adaptive Turnstile:
#   Challenge only after ≥5 failures / 10s
#   15-minute bypass cookie after passing

# RLS Tenant Isolation:
#   SET LOCAL app.current_org = <orgId>
#   Automatic multi-tenancy for all org-scoped queries

# Audit Logging:
#   All auth events → audit_logs table (append-only)
#   All auth events → PostHog for analytics

# ==============================================================================
# DEVELOPMENT QUICK START
# ==============================================================================

# 1. Copy this file:
#    cp .env.example.better-auth .env.local

# 2. Generate secrets:
#    BETTER_AUTH_SECRET=$(openssl rand -base64 32)
#    openssl genrsa -out private.pem 2048
#    openssl rsa -in private.pem -pubout -out public.pem

# 3. Set up OAuth apps:
#    GitHub: https://github.com/settings/developers
#    Google: https://console.cloud.google.com/apis/credentials

# 4. Set up Turnstile:
#    https://dash.cloudflare.com/turnstile

# 5. Set up email provider:
#    Resend: https://resend.com/api-keys

# 6. Run migrations:
#    pnpm db:migrate

# 7. Start dev server:
#    pnpm dev
