import { describe, it, expect, beforeAll } from "vitest";
import { drizzle } from "@snapback/database";
import { apiKeys, user } from "@snapback/database/drizzle/schema";
import { subscriptions } from "@snapback/database/drizzle/schema/postgres";
import { eq } from "drizzle-orm";
import { generateApiKey, hashApiKey } from "../../../lib/crypto";

// Import the actual procedure
import { validateApiKey } from "./validate-api-key";

describe("validateApiKey", () => {
	let testUser: typeof user.$inferSelect;
	let testApiKey: string;
	let hashedKey: string;

	beforeAll(async () => {
		// Check if database is available
		const db = drizzle.db;
		if (!db) {
			throw new Error("Database not available");
		}

		// Create test user
		const testUserResult = await db
			.insert(user)
			.values({
				email: "test@snapback.dev",
				name: "Test User",
				emailVerified: true,
			})
			.returning();

		if (!testUserResult || testUserResult.length === 0) {
			throw new Error("Failed to create test user");
		}
		
		testUser = testUserResult[0];

		// Create test subscription
		await db.insert(subscriptions).values({
			userId: testUser.id,
			plan: "free",
			status: "active",
		});

		// Generate and store test API key
		testApiKey = generateApiKey();
		hashedKey = await hashApiKey(testApiKey);

		await db.insert(apiKeys).values({
			userId: testUser.id,
			name: "Test Key",
			key: hashedKey,
			keyPreview: `${testApiKey.slice(0, 8)}...`,
		});
	});

	it("should return 401 for invalid API key", async () => {
		const context = {};
		const input = { key: "sb_invalid_key_12345678901234" };
		
		try {
			await validateApiKey({ input, context } as any);
			expect.fail("Should have thrown an error");
		} catch (err: any) {
			expect(err).toBeInstanceOf(Error);
			expect(err.message).toContain("Invalid API key");
		}
	});

	it("should return 401 for revoked API key", async () => {
		// Check if database is available
		const db = drizzle.db;
		if (!db) {
			throw new Error("Database not available");
		}

		// Revoke the key
		await db
			.update(apiKeys)
			.set({ revokedAt: new Date() })
			.where(eq(apiKeys.key, hashedKey));

		const context = {};
		const input = { key: testApiKey };
		
		try {
			await validateApiKey({ input, context } as any);
			expect.fail("Should have thrown an error");
		} catch (err: any) {
			expect(err).toBeInstanceOf(Error);
			expect(err.message).toContain("revoked");
		}

		// Restore the key for other tests
		await db
			.update(apiKeys)
			.set({ revokedAt: null })
			.where(eq(apiKeys.key, hashedKey));
	});

	it("should return 200 with user info for valid API key", async () => {
		const context = {};
		const input = { key: testApiKey };
		
		const result = await validateApiKey({ input, context } as any);

		expect(result).toMatchObject({
			valid: true,
			userId: testUser.id,
			apiKeyId: expect.any(String),
			permissions: expect.any(Object),
		});
	});

	it("should update lastUsedAt when key is validated", async () => {
		// Check if database is available
		const db = drizzle.db;
		if (!db) {
			throw new Error("Database not available");
		}

		const context = {};
		const input = { key: testApiKey };
		
		await validateApiKey({ input, context } as any);

		const updatedKeyResult = await db
			.select()
			.from(apiKeys)
			.where(eq(apiKeys.key, hashedKey))
			.limit(1);

		const updatedKey = updatedKeyResult && updatedKeyResult.length > 0 ? updatedKeyResult[0] : null;
		expect(updatedKey?.lastUsedAt).toBeTruthy();
	});
});