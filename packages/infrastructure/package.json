{
  "name": "@snapback/infrastructure",
  "version": "0.2.0",
  "license": "Apache-2.0",
  "author": "SnapBack Team",
  "repository": {
    "type": "git",
    "url": "https://github.com/snapback-dev/snapback.dev.git",
    "directory": "packages/infrastructure"
  },
  "private": true,
  "dependencies": {
    "@sentry/profiling-node": "catalog:",
    "@snapback/contracts": "workspace:*",
    "nanoid": "catalog:",
    "pino": "catalog:",
    "posthog-node": "catalog:"
  },
  "devDependencies": {
    "@snapback/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "diff": "catalog:",
    "pino-pretty": "catalog:",
    "posthog-js": "catalog:",
    "react": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./logging/logger": {
      "types": "./dist/logging/logger.d.ts",
      "default": "./dist/logging/logger.js"
    },
    "./metrics": {
      "types": "./dist/metrics/index.d.ts",
      "default": "./dist/metrics/index.js"
    },
    "./tracing": {
      "types": "./dist/tracing/index.d.ts",
      "default": "./dist/tracing/index.js"
    },
    "./health": {
      "types": "./dist/health/index.d.ts",
      "default": "./dist/health/index.js"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/logging/logger.d.ts",
        "default": "./dist/logging/logger.js"
      },
      "./logging/logger": {
        "types": "./dist/logging/logger.d.ts",
        "default": "./dist/logging/logger.js"
      },
      "./tracing": {
        "types": "./dist/tracing/index.d.ts",
        "default": "./dist/tracing/index.js"
      },
      "./metrics": {
        "types": "./dist/metrics/index.d.ts",
        "default": "./dist/metrics/index.js"
      }
    }
  },
  "main": "dist/index.js",
  "private": true,
  "scripts": {
    "build": "tsup && tsc --build --force",
    "check": "biome check .",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --fix .",
    "postbuild": "test -f dist/index.d.ts && node scripts/patch-dts.cjs || echo 'Warning: Type declarations not fully generated'",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "type": "module",
  "types": "dist/index.d.ts"
}
