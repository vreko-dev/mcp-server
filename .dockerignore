# Build optimization - exclude unnecessary files from Docker context

# Dependencies
node_modules
**/node_modules
**/.pnpm-store
.pnpm-debug.log*
# Keep pnpm-lock.yaml for reproducible builds
# **/pnpm-lock.yaml

# Environment files (handled separately in Docker)
.env*
!.env.example
**/.env*
!**/.env.example

# Build outputs
**/dist
**/.next
**/out
**/.turbo
.turbo

# Cache directories
**/.cache
**/cache
**/.nuxt
**/.vite

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
**/logs
**/*.log

# Development files
**/.DS_Store
**/Thumbs.db
**/*.tmp
**/*.temp
**/.vscode
**/.idea

# Testing
**/coverage
**/.nyc_output
**/playwright-report
**/test-results

# Temporary files
**/tmp
**/temp
**/.tmp
**/.temp

# Git
.git
.gitignore
**/.git
**/.gitignore

# Documentation (not needed for runtime)
*.md
!README.md
**/*.md
!**/README.md

# Docker files themselves
Dockerfile*
docker-compose*
.dockerignore

# CI/CD
.github
.gitlab-ci.yml
.travis.yml
.circleci

# Prisma local files
**/prisma/migrations
**/dev.db*

# Sharp optimization
**/node_modules/sharp