    "@types/diff": "^5.2.1",
    "pino": "9.5.0",
    "better-auth": "^1.3.34",
    "zod": "^3.22.4",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-pretty-code": "^0.14.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-smartypants": "^3.0.2"
  },
  "dependencies": {
    "@next/mdx": "^16.0.1",
    "@paralleldrive/cuid2": "catalog:",
    "@vercel/analytics": "catalog:",
    "highlight.js": "^11.11.1",
    "posthog-node": "catalog:",
    "server-only": "catalog:",
    "web-vitals": "catalog:"
