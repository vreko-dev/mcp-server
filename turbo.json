{
	"$schema": "https://turbo.build/schema.json",
	"globalDependencies": [
		"**/.env.*local",
		"biome.json",
		"tsconfig.json",
		"tsup.config.ts",
		"apps/web/next.config.mjs",
		"apps/docs/next.config.mjs"
	],
	"globalEnv": ["DATABASE_URL", "REDIS_URL", "BETTER_AUTH_URL"],
	"globalPassThroughEnv": ["NODE_OPTIONS", "CI", "VERCEL", "DOCKER_BUILDKIT", "COMPOSE_DOCKER_CLI_BUILD"],
	"tasks": {
		"validate:catalog": {
			"cache": false,
			"inputs": ["pnpm-workspace.yaml", "**/package.json"],
			"outputs": []
		},
		"validate:deps": {
			"cache": false,
			"inputs": ["pnpm-lock.yaml", "**/package.json", ".syncpackrc.json", "pnpm-workspace.yaml"]
		},
		"validate:infrastructure": {
			"cache": false,
			"inputs": [
				"pnpm-lock.yaml",
				"**/package.json",
				"**/tsconfig.json",
				"**/tsup.config.ts",
				".syncpackrc.json"
			],
			"outputs": ["reports/infrastructure-validation/**"]
		},
		"validate:exports": {
			"cache": false,
			"inputs": ["**/package.json", "**/src/**/*.ts", "**/src/**/*.tsx"],
			"outputs": []
		},
		"//#validate:exports": {
			"cache": false,
			"inputs": ["**/package.json", "**/src/**/*.ts", "**/src/**/*.tsx"],
			"outputs": []
		},
		"quality": {
			"cache": false,
			"outputs": ["reports/quality/**"],
			"inputs": ["$TURBO_DEFAULT$", "biome.json"]
		},
		"type-check": {
			"dependsOn": ["^type-check"],
			"inputs": ["$TURBO_DEFAULT$"],
			"cache": true
		},
		"build:package": {
			"outputs": ["apps/vscode/package.json"],
			"inputs": ["apps/vscode/package.base.json", "apps/vscode/package-contributes/**"]
		},
		"build": {
			"dependsOn": ["validate:catalog", "validate:infrastructure", "validate:exports", "build:package", "^generate", "^build"],
			"outputs": ["dist/**", "*.tsbuildinfo", ".next/**", "!.next/cache/**", "out/**"],
			"inputs": [
				"$TURBO_DEFAULT$",
				"apps/web/.env.local",
				"apps/docs/.env.local",
				"packages/platform/.env.local",
				"packages/auth/.env.local"
			]
		},
		"test": {
			"dependsOn": ["^build"],
			"inputs": ["src/**/*.tsx", "src/**/*.ts", "test/**/*.ts", "vitest.config.ts"],
			"outputs": ["coverage/**"],
			"cache": true
		},
		"test:e2e": {
			"dependsOn": ["^build"],
			"inputs": ["e2e/**/*", "playwright.config.ts"],
			"outputs": ["playwright-report/**"],
			"cache": false
		},
		"test:coverage": {
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", "**/*.test.ts", "**/*.spec.ts", "vitest.config.ts"],
			"outputs": ["coverage/**"]
		},
		"contract-test": {
			"dependsOn": ["build"],
			"cache": true,
			"inputs": ["$TURBO_DEFAULT$", "**/*.contract.ts"]
		},
		"analyze": {
			"dependsOn": ["build"],
			"cache": false,
			"outputs": ["reports/analyze/**"]
		},
		"analyze:bundle": {
			"dependsOn": ["build"],
			"cache": false,
			"outputs": ["reports/bundle-analysis/**"],
			"passThroughEnv": ["ANALYZE"]
		},
		"scan": {
			"dependsOn": ["build"],
			"cache": false,
			"outputs": ["reports/security/**"]
		},
		"health": {
			"cache": false,
			"outputs": ["reports/health/**"]
		},
		"pack": {
			"dependsOn": ["build"],
			"cache": false,
			"outputs": ["dist/**", "*.vsix", "out/**"]
		},
		"docker-build": {
			"dependsOn": ["build"],
			"cache": false,
			"passThroughEnv": ["DOCKER_BUILDKIT", "COMPOSE_DOCKER_CLI_BUILD"]
		},
		"deploy:preview": {
			"dependsOn": ["build"],
			"cache": false,
			"passThroughEnv": ["VERCEL_TOKEN"]
		},
		"deploy:staging": {
			"dependsOn": ["test", "build", "analyze:bundle"],
			"cache": false,
			"passThroughEnv": ["VERCEL_TOKEN", "FLY_API_TOKEN"]
		},
		"deploy:production": {
			"dependsOn": ["test", "pack", "docker-build", "analyze:bundle"],
			"cache": false,
			"passThroughEnv": ["VERCEL_TOKEN", "FLY_API_TOKEN", "NPM_TOKEN", "VSCE_PAT"]
		},
		"deploy": {
			"dependsOn": ["test", "pack", "docker-build", "analyze:bundle"],
			"cache": false,
			"passThroughEnv": ["VERCEL_TOKEN", "FLY_API_TOKEN", "NPM_TOKEN", "VSCE_PAT"]
		},
		"sync-oss": {
			"dependsOn": ["deploy"],
			"cache": false
		},
		"sync-open-source": {
			"dependsOn": ["build"],
			"cache": false
		},
		"publish": {
			"dependsOn": ["build"],
			"cache": false
		},
		"release": {
			"dependsOn": ["publish", "deploy"],
			"cache": false
		},
		"version": {
			"cache": false
		},
		"changelog": {
			"cache": false,
			"outputs": ["CHANGELOG.md"]
		},
		"changeset:version": {
			"cache": false
		},
		"clean": {
			"cache": false
		},
		"generate": {
			"cache": false,
			"inputs": ["$TURBO_DEFAULT$", "packages/platform/.env.local"]
		},
		"dev": {
			"cache": false,
			"dependsOn": ["^generate"],
			"persistent": true,
			"inputs": [
				"$TURBO_DEFAULT$",
				"apps/web/.env.local",
				"apps/docs/.env.local",
				"packages/platform/.env.local",
				"packages/auth/.env.local"
			]
		},
		"start": {
			"cache": false,
			"dependsOn": ["^generate", "^build"],
			"persistent": true
		},
		"lint": {
			"dependsOn": ["^lint"],
			"inputs": ["$TURBO_DEFAULT$", "biome.json"],
			"cache": true
		},
		"export": {
			"outputs": ["out/**"]
		},
		"seo:lint": {
			"inputs": ["**/*.{md,mdx}"],
			"outputs": []
		},
		"seo:archive": {
			"cache": false,
			"outputs": [".archive/**"]
		},
		"seo:optimize": {
			"dependsOn": ["seo:lint"],
			"inputs": ["**/*.{md,mdx}", "**/*.{jpg,jpeg,png}"],
			"outputs": ["**/optimized/**"]
		},
		"seo:validate": {
			"dependsOn": ["seo:optimize"],
			"inputs": ["**/*.{md,mdx}"],
			"outputs": []
		},
		"seo:full": {
			"dependsOn": ["seo:validate"],
			"cache": false
		},
		"@snapback/docs#build": {
			"dependsOn": ["^build"],
			"outputs": [".next/**", "!.next/cache/**"]
		},
		"@snapback/docs#dev": {
			"cache": false,
			"persistent": true
		},
		"@snapback/infrastructure#build": {
			"outputs": ["dist/**"],
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", "tsup.config.ts", "src/sentry/**/*"],
			"cache": true
		},
		"@snapback/auth#build": {
			"outputs": ["dist/**"],
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", "tsup.config.ts", "tsconfig.json", "package.json"],
			"cache": true
		},
		"@snapback/core#build": {
			"outputs": ["dist/**"],
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", "tsup.config.ts", "tsconfig.json", "package.json"],
			"cache": true
		},
		"@snapback/platform#build": {
			"outputs": ["dist/**"],
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", "tsup.config.ts", "tsconfig.json", "package.json"],
			"cache": true
		},
		"@snapback/sdk#build": {
			"outputs": ["dist/**"],
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", "tsup.config.ts", "tsconfig.json", "package.json"],
			"cache": true
		},
		"@snapback/events#build": {
			"outputs": ["dist/**"],
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", "tsup.config.ts", "package.json"],
			"cache": true
		},
		"@snapback/config#build": {
			"outputs": ["dist/**"],
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", "tsup.config.ts", "package.json"],
			"cache": true
		}
	},
	"remoteCache": {
		"signature": true
	}
}
