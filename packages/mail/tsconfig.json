{
	"extends": "@snapback/tsconfig/base.json",
	"compilerOptions": {
		"lib": ["ES2020"],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"target": "ES2020",
		"incremental": false,
		"composite": false,
		"skipLibCheck": true
	},
	"include": ["src"],
	"exclude": ["dist", "**/*.test.ts", "**/*.spec.ts"]
}
