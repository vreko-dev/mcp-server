{
  "name": "@snapback/seo-automation",
  "version": "0.1.0",
  "private": true,
  "description": "Automated SEO validation, optimization, and polish for SnapBack content",
  "type": "module",
  "scripts": {
    "seo:validate": "tsx src/validate-all.ts",
    "seo:optimize-images": "tsx src/optimize-images.ts",
    "seo:lint-markdown": "markdownlint-cli2 \"../../apps/{web,docs}/**/*.{md,mdx}\"",
    "seo:check-links": "tsx src/check-links.ts",
    "seo:generate-metadata": "tsx src/generate-metadata.ts",
    "seo:archive-clutter": "tsx src/archive-clutter.ts",
    "seo:archive-clutter:dry-run": "tsx src/archive-clutter.ts --dry-run",
    "seo:full": "pnpm seo:archive-clutter:dry-run && pnpm seo:lint-markdown && pnpm seo:optimize-images && pnpm seo:check-links && pnpm seo:validate"
  },
  "dependencies": {
    "gray-matter": "catalog:",
    "glob": "catalog:",
    "hast-util-from-html": "^2.0.3",
    "hast-util-to-text": "^4.0.2",
    "html-minifier-terser": "^7.2.0",
    "rehype-parse": "^9.0.1",
    "rehype-stringify": "^10.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "catalog:",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "sharp": "catalog:",
    "unified": "^11.0.5",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "markdownlint": "^0.36.1",
    "markdownlint-cli2": "^0.15.0",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
