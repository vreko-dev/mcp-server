{
	"extends": "@snapback/tsconfig/base.json",
	"compilerOptions": {
		"outDir": "dist",
		"rootDir": "src",
		"composite": true,
		"tsBuildInfoFile": ".tsbuildinfo",
		"typeRoots": ["./types", "./node_modules/@types"]
	},
	"include": ["src", "types/**/*.d.ts"],
	"references": [{ "path": "../config" }, { "path": "../contracts" }, { "path": "../infrastructure" }],
	"exclude": ["node_modules", "dist", ".tsbuildinfo"]
}
